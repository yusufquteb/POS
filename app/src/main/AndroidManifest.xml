<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- الصلاحيات                                               -->
    <!-- ════════════════════════════════════════════════════════ -->

    <!-- الإنترنت للـ Billing و Firebase -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <!-- الكاميرا للباركود -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false"/>

    <!-- التخزين Android 13+ -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES"/>
    <!-- التخزين Android 10-12 -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="32"
        tools:ignore="ScopedStorage"/>

    <!-- Bluetooth للطابعة الحرارية -->
    <!-- Android 12+ -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT"/>
    <uses-permission android:name="android.permission.BLUETOOTH_SCAN"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="s"/>
    <!-- Android 11 وأقل -->
    <uses-permission android:name="android.permission.BLUETOOTH" android:maxSdkVersion="30"/>
    <uses-permission android:name="android.permission.BLUETOOTH_ADMIN" android:maxSdkVersion="30"/>
    <uses-feature android:name="android.hardware.bluetooth" android:required="false"/>

    <!-- ✅ الفوترة عبر Google Play -->
    <uses-permission android:name="com.android.vending.BILLING"/>

    <!-- الإشعارات (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>

    <!-- الموقع (اختياري لتتبع الفروع) -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- التطبيق                                                 -->
    <!-- ════════════════════════════════════════════════════════ -->
    <application
        android:name=".SketchApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:description="@string/app_tagline"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:networkSecurityConfig="@xml/network_security_config"
        android:enableOnBackInvokedCallback="true"
        android:localeConfig="@xml/locales_config"
        tools:targetApi="tiramisu">

        <!-- ════════ Splash ════════ -->
        <activity
            android:name=".SplashActivity"
            android:exported="true"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- ════════ Onboarding ════════ -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/AppTheme"/>

        <!-- ════════ Auth ════════ -->
        <activity
            android:name=".AuthActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/AppTheme"/>

        <!-- ════════ Main ════════ -->
        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"/>

        <!-- ════════ Products ════════ -->
        <activity
            android:name=".ActivityProductsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="@string/products_title"/>

        <activity
            android:name=".ActivityAddProductActivity"
            android:exported="false"
            android:parentActivityName=".ActivityProductsActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/add_product"/>

        <!-- ════════ Sales / Cart ════════ -->
        <activity
            android:name=".ActivityCartActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/cart_title"/>

        <activity
            android:name=".ActivityBarcodeScannerActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:hardwareAccelerated="true"
            android:theme="@style/AppTheme"/>

        <!-- ════════ Customers & Suppliers ════════ -->
        <activity
            android:name=".ActivityCustomersActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="@string/customers_title"/>

        <activity
            android:name=".ActivitySuppliersActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="@string/suppliers_title"/>

        <!-- ════════ Invoices ════════ -->
        <activity
            android:name=".ActivityInvoicesActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="@string/invoices_title"/>

        <activity
            android:name=".ActivityInvoiceDetailsActivity"
            android:exported="false"
            android:parentActivityName=".ActivityInvoicesActivity"
            android:screenOrientation="portrait"
            android:label="@string/invoice_details"/>

        <!-- ════════ Reports & Expenses ════════ -->
        <activity
            android:name=".ActivityReportsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="@string/reports_title"/>

        <activity
            android:name=".ActivityExpensesActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/expenses_title"/>

        <!-- ════════ Settings ════════ -->
        <activity
            android:name=".ActivitySettingsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="@string/settings_title"/>

        <activity
            android:name=".ActivityStoreSettingsActivity"
            android:exported="false"
            android:parentActivityName=".ActivitySettingsActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/store_settings"/>

        <activity
            android:name=".ActivityPrinterSettingsActivity"
            android:exported="false"
            android:parentActivityName=".ActivitySettingsActivity"
            android:screenOrientation="portrait"
            android:label="@string/printer_settings"/>

        <activity
            android:name=".ActivityBackupActivity"
            android:exported="false"
            android:parentActivityName=".ActivitySettingsActivity"
            android:screenOrientation="portrait"
            android:label="@string/backup_title"/>

        <activity
            android:name=".ActivityLocationActivity"
            android:exported="false"
            android:parentActivityName=".ActivitySettingsActivity"
            android:screenOrientation="portrait"
            android:label="@string/location"/>

        <!-- ════════ Utility ════════ -->
        <activity
            android:name=".CrashActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:excludeFromRecents="true"/>

        <activity
            android:name=".DebugActivity"
            android:exported="false"
            android:screenOrientation="portrait"/>

        <!-- ════════ Returns ════════ -->
        <activity
            android:name=".ActivityReturnActivity"
            android:exported="false"
            android:parentActivityName=".ActivityInvoicesActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/return_sale"/>

        <!-- ════════ Shifts ════════ -->
        <activity
            android:name=".ActivityShiftActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/shifts_title"/>

        <!-- ════════ Debt Management ════════ -->
        <activity
            android:name=".ActivityDebtActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/debt_title"/>

        <!-- ════════ Purchase Orders ════════ -->
        <activity
            android:name=".ActivityPurchaseOrderActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="@string/purchase_orders_title"/>

        <!-- ════════ PIN Lock ════════ -->
        <activity
            android:name=".ActivityPinLockActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="قفل الكاشير"/>

        <!-- ════════ Expiry Dashboard ════════ -->
        <activity
            android:name=".ActivityExpiryDashboardActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="إدارة الصلاحية"/>

        <!-- ════════ Decision Dashboard ════════ -->
        <activity
            android:name=".ActivityDecisionDashboardActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="لوحة القرارات الذكية"/>

        <!-- ════════ Business Insights ════════ -->
        <activity
            android:name=".ActivityBusinessInsightsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="@string/business_insights_title"/>

        <!-- ════════ New Features ════════ -->
        <activity
            android:name=".ActivityChecksActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="الشيكات"/>

        <activity
            android:name=".ActivityInstallmentsActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="الأقساط"/>

        <activity
            android:name=".ActivityCashDrawerActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="الخزينة"/>

        <activity
            android:name=".ActivityStockCountActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="جرد المخزون"/>

        <activity
            android:name=".ActivityUsersActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:parentActivityName=".ActivitySettingsActivity"
            android:screenOrientation="portrait"
            android:label="إدارة المستخدمين"/>

        <!-- ════════ Wallet ════════ -->
        <activity
            android:name=".ActivityWalletActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="الخزينة"/>

        <!-- ════════ Customer / Supplier Accounts ════════ -->
        <activity
            android:name=".ActivityCustomerAccountsActivity"
            android:exported="false"
            android:parentActivityName=".ActivityCustomersActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="حساب العميل"/>

        <activity
            android:name=".ActivitySupplierAccountsActivity"
            android:exported="false"
            android:parentActivityName=".ActivitySuppliersActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="حساب المورد"/>

        <activity
            android:name=".ActivityCustomerRemainingActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="مستحقات العملاء"/>

        <activity
            android:name=".ActivitySupplierRemainingActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="مستحقات الموردين"/>

        <!-- ════════ Item Details + Price Editor ════════ -->
        <activity
            android:name=".ActivityItemDetailsActivity"
            android:exported="false"
            android:parentActivityName=".ActivityProductsActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="تفاصيل المنتج"/>

        <activity
            android:name=".ActivityEditPricesActivity"
            android:exported="false"
            android:parentActivityName=".ActivityProductsActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="تعديل الأسعار"/>

        <!-- ════════ Price Quotes ════════ -->
        <activity
            android:name=".ActivityPriceQuotesActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="عروض الأسعار"/>

        <activity
            android:name=".ActivityPriceQuoteActivity"
            android:exported="false"
            android:parentActivityName=".ActivityPriceQuotesActivity"
            android:screenOrientation="portrait"
            android:windowSoftInputMode="adjustResize"
            android:label="عرض سعر جديد"/>

        <!-- ════════ Remove Data ════════ -->
        <activity
            android:name=".ActivityRemoveDataActivity"
            android:exported="false"
            android:parentActivityName=".ActivitySettingsActivity"
            android:screenOrientation="portrait"
            android:label="حذف البيانات"/>

        <activity
            android:name=".ActivitySectionHubActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:screenOrientation="portrait"
            android:label="@string/app_name"/>

        <!-- ════════ FileProvider ════════ -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"/>
        </provider>

        <!-- ════════ WorkManager ════════ -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove"/>
        </provider>

    </application>

</manifest>
