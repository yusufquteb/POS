<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="?attr/colorSurface"
	android:orientation="vertical"
	android:layoutDirection="rtl"
	android:id="@+id/_main">
	<com.google.android.material.appbar.AppBarLayout
		android:id="@+id/app_bar_layout"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar">
		<com.google.android.material.appbar.MaterialToolbar
			android:id="@+id/toolbar"
			android:layout_width="match_parent"
			android:background="?attr/colorPrimary"
			android:layout_height="?attr/actionBarSize"
			app:title="@string/store_settings_title"
			app:titleTextColor="#FFFFFF"
			app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
			app:navigationIcon="@drawable/ic_arrow_back"
			app:navigationIconTint="#FFFFFF" />
	</com.google.android.material.appbar.AppBarLayout>
	<androidx.core.widget.NestedScrollView
		android:id="@+id/nested_scroll"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:fillViewport="true"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">
		<LinearLayout
			android:id="@+id/linear63"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="@dimen/spacing_base"
			android:orientation="vertical">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview26"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardBackgroundColor="?attr/colorSurface"
				app:cardCornerRadius="24dp"
				app:cardElevation="2dp"
				app:strokeColor="?attr/colorOutlineVariant"
				app:strokeWidth="1dp">
				<LinearLayout
					android:id="@+id/layout_select_logo"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_xl"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical"
					android:foreground="?attr/selectableItemBackground"
					android:focusable="true">
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/cardview27"
						android:layout_width="110dp"
						android:layout_height="110dp"
						app:cardCornerRadius="55dp"
						app:cardElevation="4dp"
						app:strokeColor="?attr/colorPrimary"
						app:strokeWidth="2dp">
						<ImageView
							android:id="@+id/img_store_logo"
							android:layout_width="match_parent"
							android:layout_height="match_parent"
							android:src="@drawable/icn_photo_camera_round"
							android:scaleType="centerCrop"
							android:contentDescription="@string/store_settings_logo_hint" />
					</com.google.android.material.card.MaterialCardView>
					<TextView
						android:id="@+id/textview29"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="@dimen/spacing_md"
						android:text="@string/store_settings_logo_hint"
						android:textSize="@dimen/text_sm"
						android:textColor="?attr/colorPrimary"
						android:fontFamily="@font/cairo_semibold" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview28"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_xl"
				app:cardBackgroundColor="?attr/colorSurface"
				app:cardCornerRadius="24dp"
				app:cardElevation="2dp"
				app:strokeColor="?attr/colorOutlineVariant"
				app:strokeWidth="1dp">
				<LinearLayout
					android:id="@+id/linear64"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_lg"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview30"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_lg"
						android:text="@string/store_settings_section_info"
						android:textSize="@dimen/text_base"
						android:textColor="?attr/colorPrimary"
						android:fontFamily="@font/cairo_bold" />
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/layout_store_name"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="14dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_person"
						app:startIconTint="?attr/colorPrimary"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_store_name"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="@dimen/text_md"
							android:imeOptions="actionNext"
							android:inputType="textCapWords"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/layout_store_phone"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="14dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_phone"
						app:startIconTint="?attr/colorPrimary"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_store_phone"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="@dimen/text_md"
							android:inputType="phone"
							android:imeOptions="actionNext"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/layout_store_address"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="14dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_location"
						app:startIconTint="?attr/colorPrimary"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_store_address"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="@dimen/text_md"
							android:imeOptions="actionNext"
							android:inputType="textMultiLine"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/layout_country"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="14dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
						app:startIconDrawable="@drawable/ic_location"
						app:startIconTint="?attr/colorPrimary"
						android:hint="@string/str_55a3d0"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<AutoCompleteTextView
							android:id="@+id/sp_country"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="@dimen/text_md"
							android:fontFamily="@font/cairo_regular"
							android:inputType="none"
							android:focusable="false"
							android:cursorVisible="false" />
					</com.google.android.material.textfield.TextInputLayout>

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/layout_tax_number"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_xl"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_notes"
						app:startIconTint="?attr/colorPrimary"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_tax_number"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="@dimen/text_md"
							android:imeOptions="actionDone"
							android:inputType="number"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.button.MaterialButton
						android:id="@+id/btn_save_settings"
						android:layout_width="match_parent"
						android:layout_height="56dp"
						android:text="@string/store_settings_save"
						android:textSize="@dimen/text_base"
						android:textColor="?attr/colorOnPrimary"
						android:fontFamily="@font/cairo_bold"
						app:backgroundTint="?attr/colorPrimary"
						app:cornerRadius="16dp"
						app:icon="@drawable/ic_save"
						app:iconTint="#FFFFFF"
						app:iconGravity="textStart"
						app:rippleColor="#FFFFFF" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
		</LinearLayout>
	</androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
