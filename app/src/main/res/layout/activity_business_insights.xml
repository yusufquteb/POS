<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurfaceContainerLow">

    <com.google.android.material.appbar.AppBarLayout
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="?attr/colorOnPrimary"
            app:title="@string/business_insights_title"
            app:titleTextColor="?attr/colorOnPrimary" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_base">

            <!-- ── Best Seller + Best Customer ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_best_seller"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_158bba"
                            android:textSize="@dimen/text_xs"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:fontFamily="@font/cairo_regular" />
                        <TextView
                            android:id="@+id/tv_best_seller_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:fontFamily="@font/cairo_semibold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_best_customer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_0ee2c0"
                            android:textSize="@dimen/text_xs"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:fontFamily="@font/cairo_regular" />
                        <TextView
                            android:id="@+id/tv_best_customer_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="@dimen/text_sm"
                            android:textStyle="bold"
                            android:maxLines="2"
                            android:ellipsize="end"
                            android:fontFamily="@font/cairo_semibold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── Expiry Alerts + Dead Stock ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_expiry_alert"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_420ebd"
                            android:textSize="@dimen/text_xs"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:fontFamily="@font/cairo_regular" />
                        <TextView
                            android:id="@+id/tv_expiry_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="—"
                            android:textColor="?attr/colorError"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo_bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_dead_stock"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_0d219f"
                            android:textSize="@dimen/text_xs"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:fontFamily="@font/cairo_regular" />
                        <TextView
                            android:id="@+id/tv_dead_stock_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="—"
                            android:textColor="?attr/colorSecondary"
                            android:textSize="22sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo_bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── Customer Debt + Supplier Debt ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_base"
                android:orientation="horizontal"
                android:weightSum="2">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_customer_debt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_3be404"
                            android:textSize="@dimen/text_xs"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:fontFamily="@font/cairo_regular" />
                        <TextView
                            android:id="@+id/tv_customer_debt_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0.00"
                            android:textColor="?attr/colorError"
                            android:textSize="@dimen/text_md"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo_bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_supplier_debt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="?attr/colorSurfaceContainer">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_74c215"
                            android:textSize="@dimen/text_xs"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:fontFamily="@font/cairo_regular" />
                        <TextView
                            android:id="@+id/tv_supplier_debt_total"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0.00"
                            android:textColor="?attr/colorSecondary"
                            android:textSize="@dimen/text_md"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo_bold" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- ── Quick links ── -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_sm"
                android:text="@string/quick_actions"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:fontFamily="@font/cairo_semibold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_base"
                android:orientation="horizontal"
                android:weightSum="3">

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_go_expiry"
                    android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_margin="3dp" android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical" android:padding="4dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_time"
                            android:tint="?attr/colorError"
                            android:importantForAccessibility="no" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/str_420ebd"
                            android:textSize="@dimen/text_xs" android:textColor="?attr/colorOnSurface"
                            android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_go_decision"
                    android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_margin="3dp" android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical" android:padding="4dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_inventory"
                            android:tint="?attr/colorSecondary"
                            android:importantForAccessibility="no" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/str_0d219f"
                            android:textSize="@dimen/text_xs" android:textColor="?attr/colorOnSurface"
                            android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_go_debts"
                    android:layout_width="0dp" android:layout_height="72dp"
                    android:layout_margin="3dp" android:layout_weight="1"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="?attr/colorSurfaceVariant">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                        android:gravity="center" android:orientation="vertical" android:padding="4dp">
                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_money"
                            android:tint="?attr/colorPrimary"
                            android:importantForAccessibility="no" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginTop="4dp" android:text="@string/debt_title"
                            android:textSize="@dimen/text_xs" android:textColor="?attr/colorOnSurface"
                            android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
