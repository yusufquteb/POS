<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="?attr/colorSurface"
	android:id="@+id/_main">
	<com.google.android.material.appbar.AppBarLayout
		android:fitsSystemWindows="true"
		android:id="@+id/app_bar_layout14"
		android:layout_width="match_parent"
		android:layout_height="wrap_content">
		<com.google.android.material.appbar.MaterialToolbar
			android:id="@+id/toolbar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			app:title="التقاريروالإحصائيات"
			app:navigationIcon="@drawable/ic_arrow_back" />
	</com.google.android.material.appbar.AppBarLayout>
	<androidx.core.widget.NestedScrollView
		android:id="@+id/vscroll2"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">
		<LinearLayout
			android:id="@+id/linear15"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="@dimen/spacing_base"
			android:orientation="vertical">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview5"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:id="@+id/linear16"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview11"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_md"
						android:text="@string/str_aaa378"
						android:textSize="@dimen/text_base"
						android:textStyle="bold" />
					<com.google.android.material.chip.ChipGroup
						android:id="@+id/chip_group_period"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						app:singleSelection="true"
						app:checkedChip="@id/chip_today">
						<com.google.android.material.chip.Chip
							android:id="@+id/chip_today"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							style="@style/Widget.Material3.Chip.Filter" />
						<com.google.android.material.chip.Chip
							android:id="@+id/chip_week"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							style="@style/Widget.Material3.Chip.Filter" />
						<com.google.android.material.chip.Chip
							android:id="@+id/chip_month"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							style="@style/Widget.Material3.Chip.Filter" />
						<com.google.android.material.chip.Chip
							android:id="@+id/chip_custom"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							style="@style/Widget.Material3.Chip.Filter" />
					</com.google.android.material.chip.ChipGroup>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview6"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardBackgroundColor="?attr/colorPrimaryContainer"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:id="@+id/linear17"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview12"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_base"
						android:text="@string/str_1645b6"
						android:textSize="@dimen/text_lg"
						android:textStyle="bold" />
					<LinearLayout
						android:id="@+id/linear18"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_md"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview13"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_4c33ae"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_total_sales"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/str_388b15"
							android:textSize="@dimen/text_base"
							android:textStyle="bold" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear19"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_md"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview14"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_391cd6"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_invoice_count"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="0"
							android:textSize="@dimen/text_base"
							android:textStyle="bold" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear20"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview15"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_ae854a"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_average_invoice"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/str_388b15"
							android:textSize="@dimen/text_base"
							android:textStyle="bold" />
					</LinearLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview7"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:id="@+id/linear21"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview16"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_base"
						android:text="@string/str_09293f"
						android:textSize="@dimen/text_lg"
						android:textStyle="bold" />
					<LinearLayout
						android:id="@+id/linear22"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_md"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview17"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_3a2495"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_products_count"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="0"
							android:textSize="@dimen/text_base"
							android:textStyle="bold" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear23"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_md"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview18"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_66fe38"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_inventory_value"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/str_388b15"
							android:textSize="@dimen/text_base"
							android:textStyle="bold" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear24"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview19"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_74e67c"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_low_stock"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="0"
							android:textSize="@dimen/text_base"
							android:textStyle="bold"
							android:textColor="@color/color_warning" />
					</LinearLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

			<!-- بطاقة الأرباح الكاملة -->
			<com.google.android.material.card.MaterialCardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_md"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">

					<TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_md"
						android:text="@string/str_cc6bac"
						android:textSize="@dimen/text_lg" android:textStyle="bold"/>

					<!-- تكلفة البضاعة المباعة COGS -->
					<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
						android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
						<TextView android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:text="@string/str_c725ca" android:textSize="@dimen/text_sm"/>
						<TextView android:id="@+id/tv_cogs"
							android:layout_width="wrap_content" android:layout_height="wrap_content"
							android:text="0.00" android:textSize="@dimen/text_md" android:textStyle="bold" android:textColor="?attr/colorError"/>
					</LinearLayout>

					<!-- مجمل الربح Gross Profit -->
					<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
						android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
						<TextView android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:text="@string/str_3c1254" android:textSize="@dimen/text_sm"/>
						<TextView android:id="@+id/tv_gross_profit"
							android:layout_width="wrap_content" android:layout_height="wrap_content"
							android:text="0.00" android:textSize="@dimen/text_md" android:textStyle="bold" android:textColor="?attr/colorPrimary"/>
					</LinearLayout>

					<!-- خط فاصل -->
					<View android:layout_width="match_parent" android:layout_height="1dp"
						android:background="?attr/colorOutlineVariant" android:layout_marginBottom="@dimen/spacing_sm"/>

					<!-- المصروفات -->
					<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
						android:orientation="horizontal" android:layout_marginBottom="@dimen/spacing_sm">
						<TextView android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:text="@string/expenses_title" android:textSize="@dimen/text_sm"/>
						<TextView android:id="@+id/tv_total_expenses"
							android:layout_width="wrap_content" android:layout_height="wrap_content"
							android:text="0.00" android:textSize="@dimen/text_md" android:textStyle="bold" android:textColor="?attr/colorError"/>
					</LinearLayout>

					<!-- صافي الربح Net Profit -->
					<LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
						android:orientation="horizontal">
						<TextView android:layout_width="0dp" android:layout_height="wrap_content"
							android:layout_weight="1" android:text="@string/reports_profit" android:textSize="@dimen/text_base" android:textStyle="bold"/>
						<TextView android:id="@+id/tv_net_profit"
							android:layout_width="wrap_content" android:layout_height="wrap_content"
							android:text="0.00" android:textSize="@dimen/text_lg" android:textStyle="bold" android:textColor="@color/color_success"/>
					</LinearLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview8"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:id="@+id/linear25"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview20"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_base"
						android:text="@string/str_c18be3"
						android:textSize="@dimen/text_lg"
						android:textStyle="bold" />
					<androidx.recyclerview.widget.RecyclerView
						android:id="@+id/rv_top_products"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:nestedScrollingEnabled="false"
						android:clipToPadding="false"
						android:paddingBottom="80dp"/>
					<TextView
						android:id="@+id/tv_no_top_products"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/no_sales_period"
						android:textSize="@dimen/text_md"
						android:gravity="center"
						android:padding="@dimen/spacing_base"
						android:textColor="?attr/colorOnSurfaceVariant"
						android:visibility="gone"/>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="80dp"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_md"
						android:text="المبيعات حسب الفئة"
						android:textSize="@dimen/text_lg"
						android:textStyle="bold"/>
					<androidx.recyclerview.widget.RecyclerView
						android:id="@+id/rv_sales_by_category"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:nestedScrollingEnabled="false"
						android:clipToPadding="false"/>
					<TextView
						android:id="@+id/tv_no_category_data"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="لا توجد بيانات للفترة المحددة"
						android:textSize="@dimen/text_md"
						android:gravity="center"
						android:padding="@dimen/spacing_base"
						android:textColor="?attr/colorOnSurfaceVariant"
						android:visibility="gone"/>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

			<!-- Sales Chart -->
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/card_sales_chart"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:id="@+id/tv_chart_title"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:text="@string/chart_daily_sales"
						android:textSize="@dimen/text_base"
						android:textStyle="bold"
						android:layout_marginBottom="@dimen/spacing_sm"/>
					<com.github.mikephil.charting.charts.BarChart
						android:id="@+id/bar_chart_sales"
						android:layout_width="match_parent"
						android:layout_height="220dp"/>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>

			<!-- Sales by employee -->
			<Button
				android:id="@+id/btn_sales_by_employee"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/spacing_sm"
				android:text="@string/sales_by_employee_title"
				android:drawableStart="@drawable/ic_people"
				android:drawablePadding="6dp"
				style="@style/Widget.Material3.Button.TonalButton" />

			<!-- Advanced reports section -->
			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dp"
				android:layout_marginBottom="8dp"
				android:text="@string/advanced_reports"
				android:textSize="15sp"
				android:textStyle="bold"
				android:textColor="?attr/colorOnSurface"/>

			<Button
				android:id="@+id/btn_product_profitability"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="6dp"
				android:text="@string/report_product_profitability"
				android:drawableStart="@drawable/ic_bar_chart"
				android:drawablePadding="6dp"
				style="@style/Widget.Material3.Button.TonalButton" />

			<Button
				android:id="@+id/btn_purchases_report"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="6dp"
				android:text="@string/report_purchases"
				android:drawableStart="@drawable/ic_local_shipping"
				android:drawablePadding="6dp"
				style="@style/Widget.Material3.Button.TonalButton" />

			<Button
				android:id="@+id/btn_customer_aging"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="6dp"
				android:text="@string/report_customer_aging"
				android:drawableStart="@drawable/ic_customers"
				android:drawablePadding="6dp"
				style="@style/Widget.Material3.Button.TonalButton" />

			<Button
				android:id="@+id/btn_supplier_aging"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="80dp"
				android:text="@string/report_supplier_aging"
				android:drawableStart="@drawable/ic_suppliers"
				android:drawablePadding="6dp"
				style="@style/Widget.Material3.Button.TonalButton" />
		</LinearLayout>
	</androidx.core.widget.NestedScrollView>
	<LinearLayout
		android:id="@+id/linear26"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="@dimen/spacing_base"
		android:background="?attr/colorSurface"
		android:orientation="horizontal"
		android:layout_gravity="bottom"
		android:elevation="8dp">
		<Button
			android:id="@+id/btn_export_pdf"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:text="@string/str_a6d89e"
			android:textSize="@dimen/text_xs"
			android:layout_weight="1"
			android:layout_marginEnd="@dimen/spacing_xs"
			style="@style/Widget.Material3.Button" />
		<Button
			android:id="@+id/btn_share_report"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:text="@string/str_81a50c"
			android:textSize="@dimen/text_xs"
			android:layout_weight="1"
			android:layout_marginStart="@dimen/spacing_xs"
			android:layout_marginEnd="@dimen/spacing_xs"
			style="@style/Widget.Material3.Button.TonalButton" />
		<Button
			android:id="@+id/btn_whatsapp_report"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:text="@string/str_0d8c9b"
			android:textSize="@dimen/text_xs"
			android:layout_weight="1"
			android:layout_marginStart="@dimen/spacing_xs"
			android:drawableStart="@drawable/ic_whatsapp"
			android:drawablePadding="4dp"
			style="@style/Widget.Material3.Button.OutlinedButton" />
	</LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
