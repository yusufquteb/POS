<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layoutDirection="rtl"
    android:padding="@dimen/spacing_base">

    <TextView android:id="@+id/tv_summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        android:textSize="@dimen/text_md"
        android:textColor="?attr/colorOnSurface"/>

    <TextView android:id="@+id/tv_debt_warning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/spacing_md"
        android:padding="@dimen/spacing_sm"
        android:textColor="?attr/colorError"
        android:textSize="@dimen/text_sm"
        android:visibility="gone"/>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/til_paid_amount"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="المبلغ المدفوع"
        android:layout_marginBottom="@dimen/spacing_sm"
        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_paid_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="numberDecimal"/>
    </com.google.android.material.textfield.TextInputLayout>

    <TextView android:id="@+id/tv_change"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="@dimen/spacing_sm"
        android:textSize="@dimen/text_base"
        android:textStyle="bold"
        android:visibility="gone"/>

</LinearLayout>
