<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:id="@+id/_main">
	<com.google.android.material.appbar.AppBarLayout
		android:id="@+id/app_bar_layout39"
		android:layout_width="match_parent"
		android:layout_height="wrap_content">
		<com.google.android.material.appbar.MaterialToolbar
			android:id="@+id/toolbar"
			android:layout_width="match_parent"
			android:layout_height="?attr/actionBarSize"
			app:title="تفاصيلالفاتورة"
			app:navigationIcon="@drawable/ic_arrow_back" />
	</com.google.android.material.appbar.AppBarLayout>
	<androidx.core.widget.NestedScrollView
		android:id="@+id/vscroll4"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">
		<LinearLayout
			android:id="@+id/linear40"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="@dimen/spacing_base"
			android:orientation="vertical">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview13"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardBackgroundColor="?attr/colorPrimaryContainer"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:id="@+id/linear41"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:id="@+id/tv_invoice_number"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/str_f8e65d"
						android:textSize="@dimen/text_xl"
						android:textStyle="bold" />
					<TextView
						android:id="@+id/tv_date"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="@dimen/spacing_xs"
						android:text="09/02/2026 14:30"
						android:textSize="@dimen/text_md" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview14"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:id="@+id/linear42"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview31"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_sm"
						android:text="@string/str_6fda8a"
						android:textSize="@dimen/text_base"
						android:textStyle="bold" />
					<TextView
						android:id="@+id/tv_customer_name"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_xs"
						android:text="@string/str_536589"
						android:textSize="@dimen/text_md" />
					<TextView
						android:id="@+id/tv_customer_phone"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/str_295463"
						android:textSize="@dimen/text_md" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview15"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_base"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:id="@+id/linear43"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview32"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_md"
						android:text="@string/str_b25ceb"
						android:textSize="@dimen/text_base"
						android:textStyle="bold" />
					<androidx.recyclerview.widget.RecyclerView
						android:id="@+id/recycler_items"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:clipToPadding="false"
						android:paddingBottom="80dp" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview16"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="80dp"
				app:cardElevation="2dp"
				app:cardCornerRadius="12dp">
				<LinearLayout
					android:id="@+id/linear44"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="@dimen/spacing_base"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/linear45"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_sm"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview33"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_e2f201"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_subtotal"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/str_714c39"
							android:textSize="@dimen/text_md" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/layout_discount"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_sm"
						android:orientation="horizontal"
						android:visibility="gone">
						<TextView
							android:id="@+id/textview34"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_fa1478"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_discount"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/str_6fcd73"
							android:textSize="@dimen/text_md"
							android:textColor="?attr/colorError" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/layout_tax"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="@dimen/spacing_sm"
						android:orientation="horizontal"
						android:visibility="gone">
						<TextView
							android:id="@+id/textview35"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_b59c81"
							android:textSize="@dimen/text_md"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_tax"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/str_f6b351"
							android:textSize="@dimen/text_md" />
					</LinearLayout>
					<View
						android:id="@+id/view46"
						android:layout_width="match_parent"
						android:layout_height="1dp"
						android:background="?android:attr/listDivider"
						android:layout_marginVertical="8dp" />
					<LinearLayout
						android:id="@+id/linear47"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview36"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/str_b6d0dd"
							android:textSize="@dimen/text_lg"
							android:textStyle="bold"
							android:layout_weight="1" />
						<TextView
							android:id="@+id/tv_final_total"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/str_0a9555"
							android:textSize="@dimen/text_lg"
							android:textStyle="bold" />
					</LinearLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
		</LinearLayout>
	</androidx.core.widget.NestedScrollView>
	<LinearLayout
		android:id="@+id/linear48"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="@dimen/spacing_base"
		android:background="?attr/colorSurface"
		android:orientation="horizontal"
		android:layout_gravity="bottom"
		android:elevation="8dp">
		<Button
			android:id="@+id/btn_print"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:text="@string/str_88c5d1"
			android:textSize="@dimen/text_xs"
			android:layout_weight="1"
			android:layout_marginEnd="@dimen/spacing_sm"
			style="@style/Widget.Material3.Button" />
		<Button
			android:id="@+id/btn_whatsapp"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:text="@string/str_0d8c9b"
			android:textSize="@dimen/text_xs"
			android:layout_weight="1"
			android:layout_marginStart="@dimen/spacing_sm"
			style="@style/Widget.Material3.Button.TonalButton" />
	</LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
