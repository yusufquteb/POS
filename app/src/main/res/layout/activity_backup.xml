<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="?attr/colorSurface"
	android:id="@+id/_main">

	<!-- Toolbar -->
	<LinearLayout
		android:id="@+id/toolbar"
		android:layout_width="match_parent"
		android:layout_height="56dp"
		android:gravity="center_vertical"
		android:orientation="horizontal"
		android:background="?attr/colorSurface"
		android:elevation="4dp"
		android:paddingStart="@dimen/spacing_base"
		android:paddingEnd="@dimen/spacing_base"
		android:focusable="true">
		<ImageView
			android:id="@+id/imageview3"
			android:layout_width="24dp"
			android:layout_height="24dp"
			android:scaleType="center"
			android:src="@android:drawable/ic_menu_revert"
			android:contentDescription="رجوع"
			android:tint="?attr/colorPrimary" />
		<TextView
			android:id="@+id/textview25"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:text="النسخ الاحتياطي"
			android:textSize="@dimen/text_lg"
			android:textStyle="bold"
			android:textColor="?attr/colorOnSurface"
			android:layout_weight="1"
			android:layout_marginStart="@dimen/spacing_base" />
	</LinearLayout>

	<!-- Local Backup Buttons -->
	<LinearLayout
		android:id="@+id/linear12"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="1dp"
		android:padding="@dimen/spacing_base"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="horizontal"
		android:background="?attr/colorSurface">
		<Button
			android:id="@+id/btn_create_backup"
			android:layout_width="0dp"
			android:layout_height="48dp"
			style="@style/ButtonStyle"
			android:text="إنشاء نسخة"
			android:textSize="@dimen/text_md"
			android:textStyle="bold"
			android:layout_weight="1"
			android:layout_marginEnd="@dimen/spacing_sm" />
		<Button
			android:id="@+id/btn_restore_backup"
			android:layout_width="0dp"
			android:layout_height="48dp"
			style="@style/ButtonStyle_Tonal"
			android:text="استعادة نسخة"
			android:textSize="@dimen/text_md"
			android:textStyle="bold"
			android:layout_weight="1"
			android:layout_marginStart="@dimen/spacing_sm" />
	</LinearLayout>

	<!-- Cloud Backup Card -->
	<LinearLayout
		android:id="@+id/section_cloud_backup"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="1dp"
		android:padding="@dimen/spacing_base"
		android:background="?attr/colorSurface"
		android:orientation="vertical">
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="horizontal"
			android:gravity="center_vertical">
			<TextView
				android:layout_width="0dp"
				android:layout_height="wrap_content"
				android:layout_weight="1"
				android:text="☁️ النسخ الاحتياطي على السحابة"
				android:textSize="@dimen/text_md"
				android:textStyle="bold"
				android:textColor="?attr/colorOnSurface"/>
			<TextView
				android:id="@+id/tv_cloud_status"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="غير مُفعّل"
				android:textSize="@dimen/text_xs"
				android:textColor="@color/color_warning"
				android:textStyle="bold"/>
		</LinearLayout>
		<TextView
			android:id="@+id/tv_cloud_last_backup"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="@dimen/spacing_xs"
			android:text=""
			android:textSize="@dimen/text_xs"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:visibility="gone"/>
		<LinearLayout
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="@dimen/spacing_md"
			android:orientation="horizontal">
			<Button
				android:id="@+id/btn_select_cloud_folder"
				android:layout_width="0dp"
				android:layout_height="40dp"
				android:layout_weight="1"
				style="@style/ButtonStyle_Outlined"
				android:text="اختيار مجلد"
				android:textSize="@dimen/text_xs"
				android:layout_marginEnd="6dp"/>
			<Button
				android:id="@+id/btn_cloud_backup_now"
				android:layout_width="0dp"
				android:layout_height="40dp"
				android:layout_weight="1"
				style="@style/ButtonStyle"
				android:text="نسخ الآن"
				android:textSize="@dimen/text_xs"
				android:visibility="gone"
				android:layout_marginStart="6dp"/>
		</LinearLayout>
	</LinearLayout>

	<!-- Section Header -->
	<TextView
		android:id="@+id/textview26"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="1dp"
		android:padding="@dimen/spacing_base"
		android:text="النسخ الاحتياطية المحفوظة"
		android:textSize="@dimen/text_md"
		android:textStyle="bold"
		android:textColor="?attr/colorOnSurfaceVariant"
		android:background="?attr/colorSurface" />

	<!-- Backup List -->
	<FrameLayout
		android:id="@+id/frame_layout13"
		android:layout_width="match_parent"
		android:layout_height="0dp"
		android:layout_weight="1">
		<ListView
			android:id="@+id/list_backups"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:choiceMode="none"
			android:background="?attr/colorSurface"
			android:divider="?attr/colorOutlineVariant" />
		<LinearLayout
			android:id="@+id/empty_state"
			android:layout_width="match_parent"
			android:layout_height="match_parent"
			android:padding="@dimen/spacing_xxl"
			android:gravity="center_horizontal|center_vertical"
			android:orientation="vertical"
			android:visibility="gone">
			<ImageView
				android:id="@+id/imageview4"
				android:layout_width="120dp"
				android:layout_height="120dp"
				android:scaleType="center"
				android:src="@android:drawable/ic_menu_save"
				android:tint="?attr/colorOutlineVariant"
				android:contentDescription="لاتوجدنسخ" />
			<TextView
				android:id="@+id/textview27"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/spacing_base"
				android:text="لا توجد نسخ احتياطية"
				android:textSize="@dimen/text_lg"
				android:textStyle="bold"
				android:textColor="?attr/colorOnSurface" />
			<TextView
				android:id="@+id/textview28"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="@dimen/spacing_sm"
				android:gravity="center_horizontal|center_vertical"
				android:text="قم بإنشاء نسخة احتياطية من البيانات\nللحفاظ على معلوماتك آمنة"
				android:textSize="@dimen/text_md"
				android:textColor="?attr/colorOnSurfaceVariant" />
		</LinearLayout>
	</FrameLayout>

	<!-- Info Box -->
	<LinearLayout
		android:id="@+id/linear14"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginTop="1dp"
		android:padding="@dimen/spacing_base"
		android:background="?attr/colorPrimaryContainer"
		android:orientation="vertical">
		<TextView
			android:id="@+id/textview29"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="ℹ️ معلومات هامة:"
			android:textSize="@dimen/text_sm"
			android:textStyle="bold"
			android:textColor="?attr/colorOnPrimaryContainer" />
		<TextView
			android:id="@+id/textview30"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="@dimen/spacing_sm"
			android:text="• يتم حفظ النسخ في: SmartPOS_Backups\n• استعادة النسخة ستحذف البيانات الحالية\n• احتفظ بنسخ منتظمة من بياناتك"
			android:textSize="@dimen/text_xs"
			android:textColor="?attr/colorOnPrimaryContainer"
			android:lineSpacingExtra="4dp" />
	</LinearLayout>

</LinearLayout>
