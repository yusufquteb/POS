<RelativeLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="#000000"
	android:id="@+id/_main">
	<com.journeyapps.barcodescanner.DecoratedBarcodeView
		android:id="@+id/barcode_scanner"
		android:layout_width="match_parent"
		android:layout_height="match_parent" />
	<LinearLayout
		android:id="@+id/linear5"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="16dp"
		android:background="#000000"
		android:gravity="center_vertical"
		android:orientation="horizontal">
		<ImageView
			android:id="@+id/btn_close"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:padding="12dp"
			android:src="@drawable/ic_arrow_back"
			android:scaleType="center"
			app:tint="#FFFFFF" />
		<TextView
			android:id="@+id/textview3"
			android:layout_width="0dp"
			android:layout_height="wrap_content"
			android:text="مسح الباركود"
			android:textSize="20sp"
			android:textStyle="bold"
			android:textColor="#FFFFFF"
			android:layout_weight="1"
			android:layout_marginStart="16dp" />
		<ImageView
			android:id="@+id/btn_flash"
			android:layout_width="48dp"
			android:layout_height="48dp"
			android:padding="12dp"
			android:src="@drawable/ic_flash_on"
			android:scaleType="center"
			app:tint="#FFFFFF" />
	</LinearLayout>
	<View
		android:id="@+id/view7"
		android:layout_width="280dp"
		android:layout_height="280dp"
		android:background="@drawable/scanner_frame"
		android:layout_centerInParent="true" />
	<LinearLayout
		android:id="@+id/linear8"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:layout_marginBottom="60dp"
		android:gravity="center_horizontal|center_vertical"
		android:orientation="vertical"
		android:layout_alignParentBottom="true">
		<TextView
			android:id="@+id/textview4"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="وجه الكاميرا نحو الكود"
			android:textSize="16sp"
			android:textColor="#FFFFFF" />
		<com.google.android.material.button.MaterialButton
			android:id="@+id/btn_manual_input"
			android:layout_width="wrap_content"
			android:layout_height="56dp"
			android:layout_marginTop="20dp"
			android:text="إدخال يدوي للباركود"
			android:textSize="12sp"
			android:textColor="#1D1B20"
			app:backgroundTint="#FFFFFF"
			app:icon="@drawable/ic_keyboard"
			app:iconTint="#1D1B20"
			app:cornerRadius="28dp" />
	</LinearLayout>
</RelativeLayout>
