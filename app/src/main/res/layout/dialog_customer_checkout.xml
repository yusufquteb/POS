<ScrollView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="wrap_content"
	android:fillViewport="true">
	<LinearLayout
		android:id="@+id/linear4"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="24dp"
		android:orientation="vertical">
		<TextView
			android:id="@+id/textview6"
			android:focusable="false"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="16dp"
			android:text="بيانات العميل"
			android:textSize="18sp"
			android:textStyle="bold" />
		<com.google.android.material.textfield.TextInputLayout
			android:id="@+id/textinputlayout5"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:startIconDrawable="@android:drawable/ic_menu_call"
			app:helperText="أدخل11رقم"
			app:counterEnabled="true"
			app:counterMaxLength="11"
			style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
			<com.google.android.material.textfield.TextInputEditText
				android:id="@+id/et_customer_phone"
				android:focusable="false"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:textSize="12sp"
				android:inputType="phone"
				android:maxLength="11"
				android:digits="0123456789"
				android:textDirection="ltr" />
		</com.google.android.material.textfield.TextInputLayout>
		<com.google.android.material.card.MaterialCardView
			android:id="@+id/card_customer_info"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			app:cardBackgroundColor="#E8F5E9"
			android:visibility="gone"
			app:cardElevation="0dp"
			app:strokeWidth="1dp"
			app:strokeColor="#4CAF50">
			<TextView
				android:id="@+id/tv_customer_info"
				android:focusable="false"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:padding="16dp"
				android:textSize="14sp"
				android:textColor="#2E7D32" />
		</com.google.android.material.card.MaterialCardView>
		<Button
			android:id="@+id/btn_add_customer"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="12dp"
			android:text="➕ إضافة عميل جديد"
			android:textSize="12sp"
			android:visibility="gone"
			style="@style/Widget.Material3.Button.TonalButton" />
		<View
			android:id="@+id/divider"
			android:layout_width="match_parent"
			android:layout_height="1dp"
			android:layout_marginTop="20dp"
			android:layout_marginBottom="16dp"
			android:background="?android:attr/listDivider"
			android:visibility="gone" />
		<LinearLayout
			android:id="@+id/layout_payment"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:visibility="gone">
			<TextView
				android:id="@+id/textview7"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="12dp"
				android:text="💰 تفاصيل الدفع"
				android:textSize="16sp"
				android:textStyle="bold" />
			<LinearLayout
				android:id="@+id/linear5"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="8dp"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/textview8"
					android:focusable="false"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:text="الإجمالي:"
					android:textSize="16sp"
					android:layout_weight="1" />
				<TextView
					android:id="@+id/tv_subtotal"
					android:focusable="false"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:text="0.00 ج.م"
					android:textSize="16sp"
					android:textStyle="bold" />
			</LinearLayout>
			<com.google.android.material.textfield.TextInputLayout
				android:id="@+id/textinputlayout6"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				app:prefixText="-"
				app:suffixText="ج.م"
				style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/et_discount"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="0"
					android:textSize="12sp"
					android:inputType="numberDecimal" />
			</com.google.android.material.textfield.TextInputLayout>
			<com.google.android.material.textfield.TextInputLayout
				android:id="@+id/textinputlayout7"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="8dp"
				app:prefixText="+"
				app:suffixText="ج.م"
				style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/et_tax"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:text="0"
					android:textSize="12sp"
					android:inputType="numberDecimal" />
			</com.google.android.material.textfield.TextInputLayout>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview2"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="12dp"
				app:cardBackgroundColor="?attr/colorPrimaryContainer"
				app:cardElevation="2dp">
				<LinearLayout
					android:id="@+id/linear6"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="horizontal">
					<TextView
						android:id="@+id/textview9"
						android:focusable="false"
						android:layout_width="0dp"
						android:layout_height="wrap_content"
						android:text="الإجمالي النهائي:"
						android:textSize="18sp"
						android:textStyle="bold"
						android:layout_weight="1" />
					<TextView
						android:id="@+id/tv_final_total"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="0.00 ج.م"
						android:textSize="20sp"
						android:textStyle="bold" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.textfield.TextInputLayout
				android:id="@+id/textinputlayout8"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dp"
				app:prefixText="ج.م"
				style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
				<com.google.android.material.textfield.TextInputEditText
					android:id="@+id/et_paid"
					android:focusable="false"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:textSize="12sp"
					android:inputType="numberDecimal" />
			</com.google.android.material.textfield.TextInputLayout>
			<TextView
				android:id="@+id/tv_change"
				android:focusable="false"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="12dp"
				android:padding="12dp"
				android:background="@drawable/bg_rounded_light"
				android:gravity="center_horizontal|center_vertical"
				android:text="الباقي: 0.00 ج.م"
				android:textSize="18sp"
				android:textStyle="bold" />
			<TextView
				android:id="@+id/textview10"
				android:focusable="false"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dp"
				android:layout_marginBottom="8dp"
				android:text="طريقة الدفع:"
				android:textSize="12sp"
				android:textStyle="bold" />
			<RadioGroup
				android:id="@+id/rg_payment_method"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:orientation="horizontal">
				<com.google.android.material.radiobutton.MaterialRadioButton
					android:id="@+id/rb_cash"
					android:layout_width="0dp"
					android:layout_height="wrap_content" />
				<com.google.android.material.radiobutton.MaterialRadioButton
					android:id="@+id/rb_card"
					android:layout_width="0dp"
					android:layout_height="wrap_content" />
				<com.google.android.material.radiobutton.MaterialRadioButton
					android:id="@+id/rb_transfer"
					android:layout_width="0dp"
					android:layout_height="wrap_content" />
			</RadioGroup>
		</LinearLayout>
	</LinearLayout>
</ScrollView>
