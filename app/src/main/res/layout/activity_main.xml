<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:navigationIcon="@drawable/ic_menu"
                app:title="@string/app_name"
                app:titleTextColor="?attr/colorOnPrimary" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <!-- ── Low-stock alert banner ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_alert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorErrorContainer"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:id="@+id/tv_alert_message"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="?attr/colorError"
                            android:textSize="@dimen/text_sm"
                            tools:text="تنبيه: 3 منتجات بمخزون منخفض" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="?attr/colorError"
                            android:textSize="@dimen/text_xl" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── HERO: Today Sales ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_today_sales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/today_sales"
                            android:textSize="@dimen/text_sm"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:fontFamily="@font/cairo_regular" />
                        <TextView
                            android:id="@+id/tv_today_sales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo_bold"
                            tools:text="1,250.00 ج.م" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Row: Today Invoices + Low Stock ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_base"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_today_invoices"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardBackgroundColor="?attr/colorSurfaceContainer">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">
                            <TextView
                                android:id="@+id/tv_today_invoices"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/cairo_bold"
                                tools:text="7" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/today_invoices"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_xs"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_low_stock"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardBackgroundColor="?attr/colorSurfaceContainer">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">
                            <TextView
                                android:id="@+id/tv_low_stock_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/colorError"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/cairo_bold"
                                tools:text="3" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/low_stock"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_xs"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ── Quick Actions header ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:text="@string/quick_actions"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold"
                    android:fontFamily="@font/cairo_semibold" />

                <!-- ── POS — Primary CTA, full width ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_pos"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?attr/colorPrimary">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/spacing_lg"
                        android:paddingEnd="@dimen/spacing_lg">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pos"
                                android:textSize="@dimen/text_xl"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnPrimary"
                                android:fontFamily="@font/cairo_bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_edebbd"
                                android:textSize="@dimen/text_sm"
                                android:textColor="?attr/colorOnPrimary"
                                android:alpha="0.8"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:tint="?attr/colorOnPrimary"
                            android:alpha="0.7"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Row 1: Products · Invoices -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_products"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_inventory"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/products_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_invoices"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_invoices"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/invoices_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 2: Customers · Suppliers · Reports -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_customers"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_people"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/customers_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_suppliers"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_local_shipping"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/suppliers_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_reports"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_reports"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/reports_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 3: Expenses · Settings · Returns -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_expenses"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_money"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/expenses_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_settings"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_settings"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/settings_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_returns"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_receive"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/return_sale"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 4: Shifts · Debts · Purchase Orders -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_shifts"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_time"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/shifts_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_debts"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_money"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/debt_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_purchase_orders"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_local_shipping"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/purchase_orders_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 5: Checks · Installments · Cash Drawer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_checks"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_backup"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/str_38a5d2"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_installments"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_time"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/str_59bee2"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_cash_drawer"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_money"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/str_b316fc"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Row 6: Stock Count · Users · Business Insights -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/fab_clearance"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_stock_count"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_inventory"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/str_8018fe"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_users"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_people"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/str_39d307"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Business Insights -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_insights"
                        android:layout_width="0dp" android:layout_height="80dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSecondaryContainer">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="4dp">
                            <ImageView android:layout_width="28dp" android:layout_height="28dp"
                                android:src="@drawable/ic_reports"
                                android:tint="?attr/colorOnSecondaryContainer"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="4dp" android:text="@string/business_insights_title"
                                android:textSize="@dimen/text_xs" android:textStyle="bold"
                                android:textColor="?attr/colorOnSecondaryContainer"
                                android:gravity="center" android:maxLines="2" android:ellipsize="end" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_quick_sale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/spacing_base"
            android:text="@string/quick_sale"
            app:icon="@drawable/ic_add"
            app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
