<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:openDrawer="start">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:fitsSystemWindows="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.google.android.material.appbar.MaterialToolbar
                android:id="@+id/toolbar"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize"
                android:background="?attr/colorPrimary"
                app:navigationIcon="@drawable/ic_menu"
                app:title="@string/app_name"
                app:titleTextColor="?attr/colorOnPrimary" />

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <!-- ── Low-stock alert banner ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_alert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:visibility="gone"
                    app:cardBackgroundColor="?attr/colorErrorContainer"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="0dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:padding="@dimen/spacing_md">
                        <TextView
                            android:id="@+id/tv_alert_message"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="?attr/colorError"
                            android:textSize="@dimen/text_sm"
                            tools:text="تنبيه: 3 منتجات بمخزون منخفض" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="?attr/colorError"
                            android:textSize="@dimen/text_xl" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── HERO: Today Sales ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_today_sales"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="@dimen/card_elevation"
                    app:cardBackgroundColor="?attr/colorSurfaceContainerHigh">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/spacing_lg">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/today_sales"
                            android:textSize="@dimen/text_sm"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:fontFamily="@font/cairo_regular" />
                        <TextView
                            android:id="@+id/tv_today_sales"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:textColor="?attr/colorPrimary"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/cairo_bold"
                            tools:text="1,250.00 ج.م" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Row: Today Invoices + Low Stock ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_base"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_today_invoices"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="4dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardBackgroundColor="?attr/colorSurfaceContainer">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">
                            <TextView
                                android:id="@+id/tv_today_invoices"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/colorPrimary"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/cairo_bold"
                                tools:text="7" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/today_invoices"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_xs"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_low_stock"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="@dimen/card_elevation"
                        app:cardBackgroundColor="?attr/colorSurfaceContainer">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="@dimen/spacing_md">
                            <TextView
                                android:id="@+id/tv_low_stock_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:textColor="?attr/colorError"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                android:fontFamily="@font/cairo_bold"
                                tools:text="3" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="2dp"
                                android:text="@string/low_stock"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:textSize="@dimen/text_xs"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ── POS — Primary CTA, full width ── -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/card_pos"
                    android:layout_width="match_parent"
                    android:layout_height="100dp"
                    android:layout_marginBottom="@dimen/spacing_base"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="3dp"
                    app:cardCornerRadius="@dimen/card_corner_radius"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="?attr/colorPrimary">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="@dimen/spacing_lg"
                        android:paddingEnd="@dimen/spacing_lg">
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/pos"
                                android:textSize="@dimen/text_xl"
                                android:textStyle="bold"
                                android:textColor="?attr/colorOnPrimary"
                                android:fontFamily="@font/cairo_bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/str_edebbd"
                                android:textSize="@dimen/text_sm"
                                android:textColor="?attr/colorOnPrimary"
                                android:alpha="0.8"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:tint="?attr/colorOnPrimary"
                            android:alpha="0.7"
                            android:importantForAccessibility="no" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- ── Section header ── -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:layout_marginStart="4dp"
                    android:text="@string/main_sections_header"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textSize="@dimen/text_sm"
                    android:textStyle="bold"
                    android:fontFamily="@font/cairo_semibold" />

                <!-- ── Row 1: Products + Invoices ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_products"
                        android:layout_width="0dp" android:layout_height="90dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="8dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_inventory"
                                android:tint="?attr/colorPrimary"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="@string/products_title"
                                android:textSize="@dimen/text_sm" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_semibold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_invoices"
                        android:layout_width="0dp" android:layout_height="90dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="8dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_invoices"
                                android:tint="?attr/colorPrimary"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="@string/invoices_title"
                                android:textSize="@dimen/text_sm" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_semibold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ── Row 2: Customers + Suppliers ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_customers"
                        android:layout_width="0dp" android:layout_height="90dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="8dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_people"
                                android:tint="?attr/colorPrimary"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="@string/customers_title"
                                android:textSize="@dimen/text_sm" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_semibold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="@string/hub_subtitle_customers"
                                android:textSize="10sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_suppliers"
                        android:layout_width="0dp" android:layout_height="90dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="8dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_local_shipping"
                                android:tint="?attr/colorPrimary"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="@string/suppliers_title"
                                android:textSize="@dimen/text_sm" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_semibold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="@string/hub_subtitle_suppliers"
                                android:textSize="10sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ── Row 3: Inventory + Treasury ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_inventory_hub"
                        android:layout_width="0dp" android:layout_height="90dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="8dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_inventory"
                                android:tint="?attr/colorSecondary"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="@string/hub_inventory"
                                android:textSize="@dimen/text_sm" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_semibold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="@string/hub_subtitle_inventory"
                                android:textSize="10sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_treasury_hub"
                        android:layout_width="0dp" android:layout_height="90dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="8dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_money"
                                android:tint="?attr/colorSecondary"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="@string/hub_treasury"
                                android:textSize="@dimen/text_sm" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_semibold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="@string/hub_subtitle_treasury"
                                android:textSize="10sp"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- ── Row 4: Reports + Settings ── -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/fab_clearance"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_reports"
                        android:layout_width="0dp" android:layout_height="90dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSecondaryContainer">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="8dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_reports"
                                android:tint="?attr/colorOnSecondaryContainer"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="@string/reports_title"
                                android:textSize="@dimen/text_sm" android:textStyle="bold"
                                android:textColor="?attr/colorOnSecondaryContainer"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_semibold" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="2dp" android:text="@string/hub_subtitle_reports"
                                android:textSize="10sp"
                                android:textColor="?attr/colorOnSecondaryContainer"
                                android:alpha="0.8"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_regular" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/card_settings"
                        android:layout_width="0dp" android:layout_height="90dp"
                        android:layout_margin="3dp" android:layout_weight="1"
                        app:cardCornerRadius="@dimen/card_corner_radius"
                        app:cardElevation="0dp"
                        app:cardBackgroundColor="?attr/colorSurfaceVariant">
                        <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
                            android:gravity="center" android:orientation="vertical" android:padding="8dp">
                            <ImageView android:layout_width="32dp" android:layout_height="32dp"
                                android:src="@drawable/ic_settings"
                                android:tint="?attr/colorOnSurfaceVariant"
                                android:importantForAccessibility="no" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                                android:layout_marginTop="6dp" android:text="@string/settings_title"
                                android:textSize="@dimen/text_sm" android:textStyle="bold"
                                android:textColor="?attr/colorOnSurface"
                                android:gravity="center" android:maxLines="1" android:ellipsize="end"
                                android:fontFamily="@font/cairo_semibold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- FAB -->
        <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
            android:id="@+id/fab_quick_sale"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="@dimen/spacing_base"
            android:text="@string/quick_sale"
            app:icon="@drawable/ic_add"
            app:layout_behavior="com.google.android.material.behavior.HideBottomViewOnScrollBehavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- Navigation Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/nav_view"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_main"
        app:menu="@menu/drawer_menu" />

</androidx.drawerlayout.widget.DrawerLayout>
