<androidx.coordinatorlayout.widget.CoordinatorLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical"
	android:background="?attr/colorSurface"
	android:layoutDirection="rtl"
	android:id="@+id/_main"
	android:fitsSystemWindows="true">
	<com.google.android.material.appbar.AppBarLayout
		android:id="@+id/app_bar_layout"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:theme="@style/ThemeOverlay.Material3.Dark.ActionBar">
		<com.google.android.material.appbar.MaterialToolbar
			android:id="@+id/toolbar1"
			android:layout_width="match_parent"
			android:background="?attr/colorPrimary"
			android:layout_height="?attr/actionBarSize"
			app:title="@string/add_product_title"
			app:titleTextColor="#FFFFFF"
			app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
			app:navigationIcon="@drawable/ic_arrow_back"
			app:navigationIconTint="#FFFFFF" />
	</com.google.android.material.appbar.AppBarLayout>
	<androidx.core.widget.NestedScrollView
		android:id="@+id/vscroll3"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:fillViewport="true"
		app:layout_behavior="@string/appbar_scrolling_view_behavior">
		<LinearLayout
			android:id="@+id/linear21"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:padding="14dp"
			android:orientation="vertical">
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/card_image_container"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="14dp"
				app:cardBackgroundColor="?attr/colorSurface"
				android:foreground="?attr/selectableItemBackground"
				android:focusable="true"
				app:cardCornerRadius="20dp"
				app:cardElevation="2dp"
				app:strokeColor="?attr/colorOutlineVariant"
				app:strokeWidth="1dp">
				<LinearLayout
					android:id="@+id/linear22"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="20dp"
					android:gravity="center_horizontal|center_vertical"
					android:orientation="vertical">
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/cardview7"
						android:layout_width="110dp"
						android:layout_height="110dp"
						app:cardCornerRadius="55dp"
						app:cardElevation="0dp"
						app:strokeColor="?attr/colorOutlineVariant"
						app:strokeWidth="1dp">
						<FrameLayout
							android:id="@+id/frame_layout23"
							android:layout_width="match_parent"
							android:layout_height="match_parent">
							<ImageView
								android:id="@+id/img_product"
								android:layout_width="match_parent"
								android:layout_height="match_parent"
								android:src="@drawable/icn_photo_camera_round"
								android:scaleType="centerCrop"
								android:alpha="0.5"
								android:contentDescription="@string/add_product_image_hint" />
							<com.google.android.material.floatingactionbutton.FloatingActionButton
								android:id="@+id/fab_camera"
								android:layout_width="wrap_content"
								android:layout_height="wrap_content"
								android:layout_margin="4dp"
								android:layout_gravity="bottom|end"
								app:fabSize="mini"
								app:srcCompat="@drawable/ic_camera"
								app:tint="#FFFFFF"
								app:backgroundTint="?attr/colorPrimary"
								app:elevation="4dp" />
						</FrameLayout>
					</com.google.android.material.card.MaterialCardView>
					<TextView
						android:id="@+id/textview9"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginTop="10dp"
						android:text="@string/add_product_image_hint"
						android:textSize="13sp"
						android:textColor="?attr/colorPrimary"
						android:fontFamily="@font/cairo_regular" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview8"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="14dp"
				app:cardBackgroundColor="?attr/colorSurface"
				app:cardCornerRadius="20dp"
				app:cardElevation="2dp"
				app:strokeColor="?attr/colorOutlineVariant"
				app:strokeWidth="1dp">
				<LinearLayout
					android:id="@+id/linear24"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview10"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="14dp"
						android:text="@string/add_product_section_basic"
						android:textSize="15sp"
						android:textColor="?attr/colorPrimary"
						android:fontFamily="@font/cairo_bold" />
					<LinearLayout
						android:id="@+id/linear25"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<com.google.android.material.textfield.TextInputLayout
							android:id="@+id/layout_barcode"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
							app:startIconDrawable="@drawable/ic_barcode"
							app:startIconTint="?attr/colorPrimary"
							app:boxCornerRadiusTopStart="12dp"
							app:boxCornerRadiusTopEnd="12dp"
							app:boxCornerRadiusBottomStart="12dp"
							app:boxCornerRadiusBottomEnd="12dp">
							<com.google.android.material.textfield.TextInputEditText
								android:id="@+id/et_barcode"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:textSize="13sp"
								android:imeOptions="actionNext"
								android:inputType="number"
								android:fontFamily="@font/cairo_regular" />
						</com.google.android.material.textfield.TextInputLayout>
						<com.google.android.material.button.MaterialButton
							android:id="@+id/btn_scan_barcode"
							android:layout_width="52dp"
							android:layout_height="52dp"
							android:textSize="12sp"
							android:layout_marginStart="8dp"
							style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
							app:icon="@drawable/ic_qr_code_scanner"
							app:iconPadding="0dp"
							app:cornerRadius="14dp" />
					</LinearLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/layout_name"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_label"
						app:startIconTint="?attr/colorPrimary"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_name"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="13sp"
							android:imeOptions="actionNext"
							android:inputType="textCapWords"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout10"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_scale"
						app:startIconTint="?attr/colorPrimary"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_unit"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="13sp"
							android:imeOptions="actionNext"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout11"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_bookmark"
						app:startIconTint="?attr/colorPrimary"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_brand"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="13sp"
							android:imeOptions="actionNext"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview9"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="14dp"
				app:cardBackgroundColor="?attr/colorSurface"
				app:cardCornerRadius="20dp"
				app:cardElevation="2dp"
				app:strokeColor="?attr/colorOutlineVariant"
				app:strokeWidth="1dp">
				<LinearLayout
					android:id="@+id/linear26"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview11"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="14dp"
						android:text="@string/add_product_section_pricing"
						android:textSize="15sp"
						android:textColor="?attr/colorPrimary"
						android:fontFamily="@font/cairo_bold" />
					<LinearLayout
						android:id="@+id/linear27"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:orientation="horizontal"
						android:weightSum="2">
						<com.google.android.material.textfield.TextInputLayout
							android:id="@+id/textinputlayout12"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginEnd="6dp"
							style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
							app:boxCornerRadiusTopStart="12dp"
							app:boxCornerRadiusTopEnd="12dp"
							app:boxCornerRadiusBottomStart="12dp"
							app:boxCornerRadiusBottomEnd="12dp">
							<com.google.android.material.textfield.TextInputEditText
								android:id="@+id/et_cost"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:textSize="13sp"
								android:inputType="numberDecimal"
								android:imeOptions="actionNext"
								android:fontFamily="@font/cairo_regular" />
						</com.google.android.material.textfield.TextInputLayout>
						<com.google.android.material.textfield.TextInputLayout
							android:id="@+id/layout_price"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginStart="6dp"
							style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
							app:boxCornerRadiusTopStart="12dp"
							app:boxCornerRadiusTopEnd="12dp"
							app:boxCornerRadiusBottomStart="12dp"
							app:boxCornerRadiusBottomEnd="12dp">
							<com.google.android.material.textfield.TextInputEditText
								android:id="@+id/et_price"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:textSize="13sp"
								android:inputType="numberDecimal"
								android:imeOptions="actionNext"
								android:fontFamily="@font/cairo_regular" />
						</com.google.android.material.textfield.TextInputLayout>
					</LinearLayout>
					<com.google.android.material.card.MaterialCardView
						android:id="@+id/cardview10"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						app:cardBackgroundColor="?attr/colorSurfaceVariant"
						app:cardCornerRadius="12dp"
						app:cardElevation="0dp"
						app:strokeWidth="0dp">
						<LinearLayout
							android:id="@+id/linear28"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:padding="12dp"
							android:orientation="horizontal">
							<LinearLayout
								android:id="@+id/linear29"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal"
								android:orientation="vertical"
								android:layout_weight="1">
								<TextView
									android:id="@+id/textview12"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="@string/add_product_profit"
									android:textSize="12sp"
									android:textColor="?attr/colorOnSurfaceVariant"
									android:fontFamily="@font/cairo_regular" />
								<TextView
									android:id="@+id/tv_profit"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="0.00 ج.م"
									android:textSize="16sp"
									android:textColor="@color/color_success"
									android:fontFamily="@font/cairo_bold" />
							</LinearLayout>
							<View
								android:id="@+id/view30"
								android:layout_width="1dp"
								android:layout_height="match_parent"
								android:background="?attr/colorSecondaryContainer"
								android:layout_marginHorizontal="8dp" />
							<LinearLayout
								android:id="@+id/linear31"
								android:layout_width="0dp"
								android:layout_height="wrap_content"
								android:gravity="center_horizontal"
								android:orientation="vertical"
								android:layout_weight="1">
								<TextView
									android:id="@+id/textview13"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="@string/add_product_profit_percent"
									android:textSize="12sp"
									android:textColor="?attr/colorOnSurfaceVariant"
									android:fontFamily="@font/cairo_regular" />
								<TextView
									android:id="@+id/tv_profit_percentage"
									android:layout_width="wrap_content"
									android:layout_height="wrap_content"
									android:text="0%"
									android:textSize="16sp"
									android:textColor="@color/color_success"
									android:fontFamily="@font/cairo_bold" />
							</LinearLayout>
						</LinearLayout>
					</com.google.android.material.card.MaterialCardView>
					<LinearLayout
						android:id="@+id/linear32"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:orientation="horizontal"
						android:weightSum="2">
						<com.google.android.material.textfield.TextInputLayout
							android:id="@+id/layout_qty"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginEnd="6dp"
							style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
							app:boxCornerRadiusTopStart="12dp"
							app:boxCornerRadiusTopEnd="12dp"
							app:boxCornerRadiusBottomStart="12dp"
							app:boxCornerRadiusBottomEnd="12dp">
							<com.google.android.material.textfield.TextInputEditText
								android:id="@+id/et_qty"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:textSize="13sp"
								android:imeOptions="actionNext"
								android:inputType="number"
								android:fontFamily="@font/cairo_regular" />
						</com.google.android.material.textfield.TextInputLayout>
						<com.google.android.material.textfield.TextInputLayout
							android:id="@+id/textinputlayout15"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							android:layout_marginStart="6dp"
							style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
							app:boxCornerRadiusTopStart="12dp"
							app:boxCornerRadiusTopEnd="12dp"
							app:boxCornerRadiusBottomStart="12dp"
							app:boxCornerRadiusBottomEnd="12dp">
							<com.google.android.material.textfield.TextInputEditText
								android:id="@+id/et_reorder_level"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:textSize="13sp"
								android:imeOptions="actionNext"
								android:inputType="number"
								android:fontFamily="@font/cairo_regular" />
						</com.google.android.material.textfield.TextInputLayout>
					</LinearLayout>
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout16"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_date"
						app:startIconTint="?attr/colorPrimary"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_expiry"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="13sp"
							android:fontFamily="@font/cairo_regular"
							android:focusable="false"
							android:focusableInTouchMode="false"
							android:cursorVisible="false" />
					</com.google.android.material.textfield.TextInputLayout>

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout_batch"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						android:hint="رقم الدفعة / الباتش"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_batch_number"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="13sp"
							android:imeOptions="actionNext"
							android:inputType="text"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview11"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="14dp"
				app:cardBackgroundColor="?attr/colorSurface"
				app:cardCornerRadius="20dp"
				app:cardElevation="2dp"
				app:strokeColor="?attr/colorOutlineVariant"
				app:strokeWidth="1dp">
				<LinearLayout
					android:id="@+id/linear33"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<TextView
						android:id="@+id/textview14"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:layout_marginBottom="14dp"
						android:text="@string/add_product_section_supply"
						android:textSize="15sp"
						android:textColor="?attr/colorPrimary"
						android:fontFamily="@font/cairo_bold" />
					<LinearLayout
						android:id="@+id/linear34"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<com.google.android.material.textfield.TextInputLayout
							android:id="@+id/textinputlayout114"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
							app:startIconDrawable="@drawable/ic_location_on"
							app:startIconTint="?attr/colorPrimary"
							app:boxCornerRadiusTopStart="12dp"
							app:boxCornerRadiusTopEnd="12dp"
							app:boxCornerRadiusBottomStart="12dp"
							app:boxCornerRadiusBottomEnd="12dp">
							<AutoCompleteTextView
								android:id="@+id/spinner_location"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:textSize="13sp"
								android:textColor="?attr/colorOnSurface"
								android:inputType="none"
								android:fontFamily="@font/cairo_regular" />
						</com.google.android.material.textfield.TextInputLayout>
						<com.google.android.material.button.MaterialButton
							android:id="@+id/btn_add_location"
							android:layout_width="52dp"
							android:layout_height="52dp"
							android:textSize="12sp"
							android:layout_marginStart="8dp"
							style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
							app:icon="@drawable/ic_add_location"
							app:iconPadding="0dp"
							app:cornerRadius="14dp" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear35"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<com.google.android.material.textfield.TextInputLayout
							android:id="@+id/textinputlayout115"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
							app:startIconDrawable="@drawable/ic_person"
							app:startIconTint="?attr/colorPrimary"
							app:boxCornerRadiusTopStart="12dp"
							app:boxCornerRadiusTopEnd="12dp"
							app:boxCornerRadiusBottomStart="12dp"
							app:boxCornerRadiusBottomEnd="12dp">
							<AutoCompleteTextView
								android:id="@+id/et_supplier"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:textSize="13sp"
								android:textColor="?attr/colorOnSurface"
								android:inputType="none"
								android:fontFamily="@font/cairo_regular" />
						</com.google.android.material.textfield.TextInputLayout>
						<com.google.android.material.button.MaterialButton
							android:id="@+id/btn_add_supplier"
							android:layout_width="52dp"
							android:layout_height="52dp"
							android:textSize="12sp"
							android:layout_marginStart="8dp"
							style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
							app:icon="@drawable/ic_person_add"
							app:iconPadding="0dp"
							app:cornerRadius="14dp" />
					</LinearLayout>
					<LinearLayout
						android:id="@+id/linear36"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<com.google.android.material.textfield.TextInputLayout
							android:id="@+id/layout_category"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:layout_weight="1"
							style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
							app:startIconDrawable="@drawable/ic_category"
							app:startIconTint="?attr/colorPrimary"
							app:boxCornerRadiusTopStart="12dp"
							app:boxCornerRadiusTopEnd="12dp"
							app:boxCornerRadiusBottomStart="12dp"
							app:boxCornerRadiusBottomEnd="12dp">
							<AutoCompleteTextView
								android:id="@+id/spinner_category"
								android:layout_width="match_parent"
								android:layout_height="wrap_content"
								android:textSize="13sp"
								android:textColor="?attr/colorOnSurface"
								android:inputType="none"
								android:fontFamily="@font/cairo_regular" />
						</com.google.android.material.textfield.TextInputLayout>
						<com.google.android.material.button.MaterialButton
							android:id="@+id/btn_add_category"
							android:layout_width="52dp"
							android:layout_height="52dp"
							android:textSize="12sp"
							android:layout_marginStart="8dp"
							style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
							app:icon="@drawable/ic_add"
							app:iconPadding="0dp"
							app:cornerRadius="14dp" />
					</LinearLayout>

					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/textinputlayout_supplier_ref"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginTop="12dp"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						android:hint="رقم مرجع المورد"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_supplier_reference"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:textSize="13sp"
							android:imeOptions="actionNext"
							android:inputType="text"
							android:fontFamily="@font/cairo_regular" />
					</com.google.android.material.textfield.TextInputLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/cardview12"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="14dp"
				app:cardBackgroundColor="?attr/colorSurface"
				app:cardCornerRadius="20dp"
				app:cardElevation="2dp"
				app:strokeColor="?attr/colorOutlineVariant"
				app:strokeWidth="1dp">
				<LinearLayout
					android:id="@+id/linear37"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<com.google.android.material.textfield.TextInputLayout
						android:id="@+id/layout_notes"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
						app:startIconDrawable="@drawable/ic_notes"
						app:startIconTint="?attr/colorPrimary"
						app:counterEnabled="true"
						app:counterMaxLength="200"
						app:boxCornerRadiusTopStart="12dp"
						app:boxCornerRadiusTopEnd="12dp"
						app:boxCornerRadiusBottomStart="12dp"
						app:boxCornerRadiusBottomEnd="12dp">
						<com.google.android.material.textfield.TextInputEditText
							android:id="@+id/et_notes"
							android:layout_width="match_parent"
							android:layout_height="wrap_content"
							android:gravity="top"
							android:textSize="13sp"
							android:imeOptions="actionDone"
							android:fontFamily="@font/cairo_regular"
							android:minLines="3"
							android:maxLength="200" />
					</com.google.android.material.textfield.TextInputLayout>
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<com.google.android.material.card.MaterialCardView
				android:id="@+id/card_saved_products"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="14dp"
				app:cardBackgroundColor="?attr/colorSurface"
				app:cardCornerRadius="20dp"
				app:cardElevation="2dp"
				app:strokeColor="?attr/colorOutlineVariant"
				app:strokeWidth="1dp">
				<LinearLayout
					android:id="@+id/linear38"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="16dp"
					android:orientation="vertical">
					<LinearLayout
						android:id="@+id/linear39"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:layout_marginBottom="12dp"
						android:gravity="center_vertical"
						android:orientation="horizontal">
						<TextView
							android:id="@+id/textview15"
							android:layout_width="0dp"
							android:layout_height="wrap_content"
							android:text="@string/add_product_section_saved"
							android:textSize="15sp"
							android:textColor="?attr/colorPrimary"
							android:layout_weight="1"
							android:fontFamily="@font/cairo_bold" />
						<TextView
							android:id="@+id/textview16"
							android:layout_width="wrap_content"
							android:layout_height="wrap_content"
							android:text="@string/swipe_hint"
							android:textSize="11sp"
							android:textColor="?attr/colorOnSurfaceVariant"
							android:fontFamily="@font/cairo_light" />
					</LinearLayout>
					<androidx.recyclerview.widget.RecyclerView
						android:id="@+id/recycler_products"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:nestedScrollingEnabled="false"
						app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />
				</LinearLayout>
			</com.google.android.material.card.MaterialCardView>
			<LinearLayout
				android:id="@+id/linear40"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="8dp"
				android:orientation="horizontal">
				<com.google.android.material.button.MaterialButton
					android:id="@+id/btn_save_and_new"
					android:layout_width="0dp"
					android:layout_height="56dp"
					android:text="@string/add_product_save_and_new"
					android:textSize="13sp"
					android:layout_weight="1"
					android:fontFamily="@font/cairo_semibold"
					android:layout_marginEnd="8dp"
					style="@style/Widget.Material3.Button.OutlinedButton"
					app:cornerRadius="14dp" />
				<com.google.android.material.button.MaterialButton
					android:id="@+id/btn_save"
					android:layout_width="0dp"
					android:layout_height="56dp"
					android:text="@string/add_product_save"
					android:textSize="15sp"
					android:layout_weight="1"
					android:fontFamily="@font/cairo_bold"
					app:backgroundTint="?attr/colorPrimary"
					app:cornerRadius="14dp"
					app:icon="@drawable/ic_save"
					app:iconTint="#FFFFFF"
					app:rippleColor="#FFFFFF" />
			</LinearLayout>
			
			<!-- Progress Bar -->
			<ProgressBar
				android:id="@+id/progress_bar"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_gravity="center"
				android:layout_marginTop="16dp"
				android:visibility="gone"
				android:indeterminateTint="#6750A4" />
			
			<!-- Hidden Elements for Compatibility -->
			<com.google.android.material.button.MaterialButton
				android:id="@+id/btn_clear"
				android:layout_width="0dp"
				android:layout_height="0dp"
				android:visibility="gone" />
			
			<com.google.android.material.button.MaterialButton
				android:id="@+id/btn_scan"
				android:layout_width="0dp"
				android:layout_height="0dp"
				android:visibility="gone" />
				
		</LinearLayout>
	</androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
