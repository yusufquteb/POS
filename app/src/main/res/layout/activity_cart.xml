<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface">

    <com.google.android.material.appbar.AppBarLayout
        android:fitsSystemWindows="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/cart_title"
            app:navigationIcon="@drawable/ic_arrow_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main content: RecyclerView fills middle, bottom panel always anchored -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ── Customer + Payment ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/spacing_base"
            android:paddingEnd="@dimen/spacing_base"
            android:paddingTop="@dimen/spacing_sm"
            android:paddingBottom="@dimen/spacing_sm">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="12dp"
                app:cardElevation="1dp"
                android:layout_marginBottom="@dimen/spacing_sm">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_base"
                    android:paddingEnd="4dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp">
                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        android:tint="?attr/colorOnSurfaceVariant"
                        android:importantForAccessibility="no" />
                    <TextView
                        android:id="@+id/tv_selected_customer"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:text="@string/no_customer_selected"
                        android:textSize="@dimen/text_base"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/cairo_regular"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_select_customer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/select"
                        style="@style/Widget.Material3.Button.TextButton"
                        android:fontFamily="@font/cairo_semibold"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_payment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_cash"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_cash"
                    android:tag="cash"
                    android:checked="true"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:fontFamily="@font/cairo_regular"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_card"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_card"
                    android:tag="card"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:fontFamily="@font/cairo_regular"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_credit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_credit"
                    android:tag="credit"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:fontFamily="@font/cairo_regular"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_vodafone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_vodafone"
                    android:tag="vodafone"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:fontFamily="@font/cairo_regular"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_instapay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_instapay"
                    android:tag="instapay"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:fontFamily="@font/cairo_regular"/>
                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_split"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/payment_split"
                    android:tag="split"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:fontFamily="@font/cairo_regular"/>
            </com.google.android.material.chip.ChipGroup>

        </LinearLayout>

        <!-- ── Cart Items (expands to fill available space) ── -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingStart="@dimen/spacing_base"
            android:paddingEnd="@dimen/spacing_base">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_cart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:visibility="gone"/>

            <LinearLayout
                android:id="@+id/empty_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="visible">
                <ImageView
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:src="@drawable/ic_shopping_cart_empty"
                    android:tint="?attr/colorOutlineVariant"
                    android:contentDescription="@string/empty_cart"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cart_empty"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:fontFamily="@font/cairo_bold"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/cart_add_products"
                    android:textSize="@dimen/text_md"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:layout_marginTop="6dp"
                    android:fontFamily="@font/cairo_regular"/>
            </LinearLayout>

        </FrameLayout>

        <!-- ── Bottom Panel (always visible, never scrolls away) ── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:elevation="8dp"
            android:background="?attr/colorSurface">

            <!-- Totals card (shown when cart has items) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_totals"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="0dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                android:visibility="gone">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="@dimen/spacing_base"
                    android:paddingEnd="@dimen/spacing_base"
                    android:paddingTop="@dimen/spacing_sm"
                    android:paddingBottom="@dimen/spacing_sm">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/discount_hint"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox.Dense"
                        android:layout_marginBottom="@dimen/spacing_sm"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_discount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:maxLines="1"
                            android:fontFamily="@font/cairo_regular"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="@string/subtotal" android:textSize="@dimen/text_md"
                            android:textColor="?attr/colorOnPrimaryContainer" android:fontFamily="@font/cairo_regular"/>
                        <TextView android:id="@+id/tv_subtotal" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00" android:textSize="@dimen/text_base" android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimaryContainer" android:fontFamily="@font/cairo_bold"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="4dp">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="@string/discount_amount" android:textSize="@dimen/text_md"
                            android:textColor="?attr/colorOnPrimaryContainer" android:fontFamily="@font/cairo_regular"/>
                        <TextView android:id="@+id/tv_discount" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00" android:textSize="@dimen/text_base" android:textStyle="bold"
                            android:textColor="?attr/colorError" android:fontFamily="@font/cairo_bold"/>
                    </LinearLayout>

                    <LinearLayout android:id="@+id/row_tax" android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:layout_marginBottom="4dp" android:visibility="gone">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="@string/tax" android:textSize="@dimen/text_md"
                            android:textColor="?attr/colorOnPrimaryContainer" android:fontFamily="@font/cairo_regular"/>
                        <TextView android:id="@+id/tv_tax" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00" android:textSize="@dimen/text_base" android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimaryContainer" android:fontFamily="@font/cairo_bold"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="?attr/colorOnPrimaryContainer" android:alpha="0.3" android:layout_marginVertical="6dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
                            android:text="@string/final_total" android:textSize="@dimen/text_lg" android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimaryContainer" android:fontFamily="@font/cairo_bold"/>
                        <TextView android:id="@+id/tv_total" android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="0.00" android:textSize="@dimen/text_xxl" android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimaryContainer" android:fontFamily="@font/cairo_bold"/>
                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons (always present) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/spacing_base"
                android:paddingEnd="@dimen/spacing_base"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_base">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_checkout"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="@string/cart_checkout"
                    android:textSize="@dimen/text_base"
                    app:icon="@drawable/ic_check"
                    app:iconGravity="textStart"
                    app:cornerRadius="14dp"
                    android:layout_marginBottom="@dimen/spacing_sm"
                    android:fontFamily="@font/cairo_semibold"
                    android:enabled="false"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_clear"
                    android:layout_width="match_parent"
                    android:layout_height="44dp"
                    android:text="@string/cart_clear"
                    app:icon="@drawable/ic_delete"
                    app:iconGravity="textStart"
                    app:cornerRadius="14dp"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:fontFamily="@font/cairo_semibold"
                    android:enabled="false"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- FABs float above the static bottom panel -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_scan_barcode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/spacing_base"
        android:layout_marginBottom="148dp"
        app:srcCompat="@drawable/ic_barcode_scanner"
        android:contentDescription="@string/scan_barcode"/>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/btn_add_product"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="@dimen/spacing_base"
        android:layout_marginBottom="88dp"
        android:text="@string/cart_add_product"
        app:icon="@drawable/ic_add"
        android:fontFamily="@font/cairo_semibold"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
