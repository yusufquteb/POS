<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/spacing_xs"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/spacing_md"
        android:gravity="center_vertical">

        <!-- Status indicator -->
        <View
            android:id="@+id/view_status_bar"
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:layout_marginEnd="@dimen/spacing_md"
            android:background="@color/color_error" />

        <!-- Product info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_product_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_md"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/str_1ab391" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="@dimen/spacing_xxs">

                <TextView
                    android:id="@+id/tv_batch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:text="@string/str_f77fa3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:text=" · "
                    android:visibility="visible" />

                <TextView
                    android:id="@+id/tv_supplier"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:maxLines="1"
                    android:text="@string/str_420f83" />

            </LinearLayout>

        </LinearLayout>

        <!-- Right side: qty + expiry badge -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tv_qty"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_sm"
                android:textStyle="bold"
                android:gravity="end"
                android:text="@string/str_d24edc" />

            <TextView
                android:id="@+id/tv_expiry_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_xs"
                android:paddingHorizontal="@dimen/spacing_sm"
                android:paddingVertical="@dimen/spacing_xxs"
                android:textSize="@dimen/text_xs"
                android:textColor="?attr/colorOnError"
                android:background="?attr/colorError"
                android:gravity="center"
                android:text="@string/str_42c40c" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
