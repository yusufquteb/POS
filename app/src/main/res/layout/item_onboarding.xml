<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xxl"
    android:gravity="center">

    <!-- Image -->
    <ImageView
        android:id="@+id/iv_onboarding_image"
        android:layout_width="280dp"
        android:layout_height="280dp"
        android:scaleType="fitCenter"
        android:contentDescription="@string/onboarding_image" />

    <View
        android:layout_width="match_parent"
        android:layout_height="40dp" />

    <!-- Title -->
    <TextView
        android:id="@+id/tv_onboarding_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_display"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:fontFamily="@font/cairo_bold" />

    <!-- Description -->
    <TextView
        android:id="@+id/tv_onboarding_description"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="@dimen/text_base"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:gravity="center"
        android:layout_marginTop="@dimen/spacing_base"
        android:lineSpacingExtra="4dp"
        android:fontFamily="@font/cairo_regular" />

</LinearLayout>
