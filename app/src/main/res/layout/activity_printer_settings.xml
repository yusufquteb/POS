<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="?attr/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="?attr/colorPrimary"
            android:elevation="4dp"
            app:title="إعدادات الطابعة"
            app:titleTextColor="?attr/colorOnPrimary" />

        <!-- نوع الاتصال -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_base"
            android:layout_marginTop="@dimen/spacing_base"
            android:layout_marginEnd="@dimen/spacing_base"
            android:text="نوع الاتصال"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_base"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <RadioGroup
                android:id="@+id/rg_connection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <RadioButton
                    android:id="@+id/rb_usb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="🔌 USB"
                    android:textSize="@dimen/text_base"
                    android:padding="@dimen/spacing_md"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rb_bluetooth"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📶 Bluetooth"
                    android:textSize="@dimen/text_base"
                    android:padding="@dimen/spacing_md" />

                <RadioButton
                    android:id="@+id/rb_wifi"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="📡 WiFi"
                    android:textSize="@dimen/text_base"
                    android:padding="@dimen/spacing_md" />

            </RadioGroup>

        </com.google.android.material.card.MaterialCardView>

        <!-- زر فحص الطابعة -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_check_printer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginStart="@dimen/spacing_base"
            android:layout_marginEnd="@dimen/spacing_base"
            android:layout_marginBottom="@dimen/spacing_sm"
            android:text="🔍 فحص الطابعة"
            android:textSize="@dimen/text_base"
            style="@style/Widget.Material3.Button.TonalButton"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_search"
            app:iconGravity="textStart" />

        <!-- إعدادات الورق -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_base"
            android:layout_marginTop="@dimen/spacing_sm"
            android:layout_marginEnd="@dimen/spacing_base"
            android:text="إعدادات الورق"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_base"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="عرض الورق"
                    android:textSize="@dimen/text_md"
                    android:textColor="@android:color/darker_gray" />

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                    <AutoCompleteTextView
                        android:id="@+id/sp_paper_width"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="80mm"
                        android:inputType="none"
                        android:textSize="@dimen/text_base" />

                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- خيارات الطباعة -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/spacing_base"
            android:layout_marginEnd="@dimen/spacing_base"
            android:text="خيارات الطباعة"
            android:textSize="@dimen/text_lg"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_base"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <!-- الطباعة التلقائية -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_sm">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🖨️ الطباعة التلقائية"
                            android:textSize="@dimen/text_base"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="طباعة الفاتورة تلقائياً بعد البيع"
                            android:textSize="@dimen/text_xs"
                            android:textColor="@android:color/darker_gray" />

                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_auto_print"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="?attr/colorOutlineVariant"
                    android:layout_marginVertical="8dp" />

                <!-- إظهار الشعار -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_sm">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="🏪 إظهار الشعار"
                            android:textSize="@dimen/text_base"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="عرض شعار المتجر في الفواتير"
                            android:textSize="@dimen/text_xs"
                            android:textColor="@android:color/darker_gray" />

                    </LinearLayout>

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_show_logo"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- الأزرار -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_margin="@dimen/spacing_base"
            android:gravity="center">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_test_print"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/spacing_sm"
                android:text="📄 اختبار"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:cornerRadius="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/spacing_sm"
                android:text="💾 حفظ"
                app:cornerRadius="12dp" />

        </LinearLayout>

        <!-- معلومات مفيدة -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/spacing_base"
            app:cardCornerRadius="12dp"
            app:cardBackgroundColor="?attr/colorSurfaceVariant"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="💡 نصائح مهمة"
                    android:textSize="@dimen/text_md"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnPrimaryContainer" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="• اضغط على 'فحص الطابعة' للتأكد من الاتصال\n• تأكد من تشغيل الطابعة قبل الفحص\n• للبلوتوث: اقترن بالطابعة أولاً من إعدادات الجهاز\n• للواي فاي: تأكد من الاتصال بنفس الشبكة"
                    android:textSize="@dimen/text_xs"
                    android:textColor="?attr/colorOnSurface"
                    android:lineSpacingExtra="4dp" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>
