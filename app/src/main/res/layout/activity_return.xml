<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:layoutDirection="rtl">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/return_sale"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleCentered="false"
            app:navigationIcon="@drawable/ic_arrow_back" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="@dimen/spacing_xl">

            <!-- ── Stats banner ───────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="@dimen/spacing_base"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorPrimaryContainer">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="@dimen/spacing_lg"
                    android:gravity="center_vertical">

                    <!-- Returns count -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_returns_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="@dimen/text_display_lg"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:fontFamily="@font/cairo_bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_cebacf"
                            android:textSize="@dimen/text_xs"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:fontFamily="@font/cairo_regular"
                            android:alpha="0.8"
                            android:layout_marginTop="@dimen/spacing_xxs" />

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="1dp"
                        android:layout_height="52dp"
                        android:background="?attr/colorOnPrimaryContainer"
                        android:alpha="0.2"
                        android:layout_marginHorizontal="16dp" />

                    <!-- Total refunded -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tv_total_refunded"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_4d2f34"
                            android:textSize="@dimen/text_xxl"
                            android:textStyle="bold"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:fontFamily="@font/cairo_bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/str_17266b"
                            android:textSize="@dimen/text_xs"
                            android:textColor="?attr/colorOnPrimaryContainer"
                            android:fontFamily="@font/cairo_regular"
                            android:alpha="0.8"
                            android:layout_marginTop="@dimen/spacing_xxs" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ── Section label ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_base"
                android:paddingBottom="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_receive"
                    android:tint="?attr/colorPrimary"
                    android:contentDescription="مرتجعات" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="@string/str_2935b1"
                    android:textSize="@dimen/text_base"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/cairo_semibold" />

            </LinearLayout>

            <!-- ── Invoice RecyclerView ──────────────────────────────── -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_invoices"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

            <!-- ── Empty state ────────────────────────────────────────── -->
            <LinearLayout
                android:id="@+id/tv_empty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="72dp"
                android:paddingBottom="@dimen/spacing_xxxl"
                android:paddingHorizontal="@dimen/spacing_xxl"
                android:visibility="gone">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:src="@drawable/ic_invoices"
                    android:tint="?attr/colorOutlineVariant"
                    android:contentDescription="لا توجد فواتير" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_base"
                    android:text="@string/str_e68917"
                    android:textSize="@dimen/text_lg"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/cairo_bold"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:text="@string/str_a1a4c8"
                    android:textSize="@dimen/text_md"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:fontFamily="@font/cairo_regular"
                    android:gravity="center"
                    android:lineSpacingMultiplier="1.5" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
