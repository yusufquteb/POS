<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	xmlns:tools="http://schemas.android.com/tools"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:orientation="vertical">
	<LinearLayout
		android:id="@+id/linear59"
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:padding="@dimen/spacing_xl"
		android:orientation="vertical"
		android:background="?attr/colorSurface">
		<TextView
			android:id="@+id/textview76"
			android:focusable="false"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="@string/str_dc428c"
			android:textSize="@dimen/text_headline"
			android:textStyle="bold"
			android:textColor="?attr/colorOnSurface"
			android:layout_gravity="center_horizontal" />
		<TextView
			android:id="@+id/textview77"
			android:focusable="false"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginTop="@dimen/spacing_xs"
			android:layout_marginBottom="@dimen/spacing_xl"
			android:text="@string/str_f64223"
			android:textSize="@dimen/text_md"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:layout_gravity="center_horizontal" />
		<LinearLayout
			android:id="@+id/linear60"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginBottom="@dimen/spacing_xl"
			android:orientation="vertical">
			<LinearLayout
				android:id="@+id/linear61"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_md"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/textview78"
					android:focusable="false"
					android:layout_width="32dp"
					android:layout_height="32dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="♾️"
					android:textSize="@dimen/text_xl" />
				<LinearLayout
					android:id="@+id/linear62"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:layout_weight="1"
					android:layout_marginStart="@dimen/spacing_md">
					<TextView
						android:id="@+id/textview79"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/str_180857"
						android:textSize="@dimen/text_base"
						android:textStyle="bold"
						android:textColor="?attr/colorOnSurface" />
					<TextView
						android:id="@+id/textview80"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/str_01903c"
						android:textSize="@dimen/text_sm"
						android:textColor="?attr/colorOnSurfaceVariant" />
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear63"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_md"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/textview81"
					android:focusable="false"
					android:layout_width="32dp"
					android:layout_height="32dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="☁️"
					android:textSize="@dimen/text_xl" />
				<LinearLayout
					android:id="@+id/linear64"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:layout_weight="1"
					android:layout_marginStart="@dimen/spacing_md">
					<TextView
						android:id="@+id/textview82"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/str_e259dc"
						android:textSize="@dimen/text_base"
						android:textStyle="bold"
						android:textColor="?attr/colorOnSurface" />
					<TextView
						android:id="@+id/textview83"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/str_29cb04"
						android:textSize="@dimen/text_sm"
						android:textColor="?attr/colorOnSurfaceVariant" />
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear65"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_md"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/textview84"
					android:focusable="false"
					android:layout_width="32dp"
					android:layout_height="32dp"
					android:gravity="center_horizontal|center_vertical"
					android:text="📊"
					android:textSize="@dimen/text_xl" />
				<LinearLayout
					android:id="@+id/linear66"
					android:layout_width="0dp"
					android:layout_height="wrap_content"
					android:orientation="vertical"
					android:layout_weight="1"
					android:layout_marginStart="@dimen/spacing_md">
					<TextView
						android:id="@+id/textview85"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/str_1e1073"
						android:textSize="@dimen/text_base"
						android:textStyle="bold"
						android:textColor="?attr/colorOnSurface" />
					<TextView
						android:id="@+id/textview86"
						android:focusable="false"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:text="@string/str_f8791a"
						android:textSize="@dimen/text_sm"
						android:textColor="?attr/colorOnSurfaceVariant" />
				</LinearLayout>
			</LinearLayout>
			<LinearLayout
				android:id="@+id/linear67"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginBottom="@dimen/spacing_md"
				android:orientation="horizontal">
				<TextView
					android:id="@+id/textview87"
					android:focusable="false"
					android:layout_width="32dp"
