<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/coordinator_shift"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:layoutDirection="rtl">

    <!-- ══════════════════════════════════════════════ -->
    <!-- AppBar                                         -->
    <!-- ══════════════════════════════════════════════ -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/shift_title"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:navigationIcon="@drawable/ic_arrow_back" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ══════════════════════════════════════════════ -->
    <!-- Scrollable Content                             -->
    <!-- ══════════════════════════════════════════════ -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="@dimen/spacing_xl"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="@dimen/spacing_sm">

            <!-- ════════════════════════════════════════ -->
            <!-- Current Shift Status Card               -->
            <!-- ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_shift_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="@dimen/spacing_sm"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="24dp"
                app:cardElevation="4dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <!-- Status Header Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_schedule"
                            android:tint="?attr/colorOnPrimaryContainer"
                            android:contentDescription="@string/shift_title" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="@dimen/spacing_md">

                            <TextView
                                android:id="@+id/tv_shift_status_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/shift_current_status"
                                android:textSize="@dimen/text_sm"
                                android:textColor="?attr/colorOnPrimaryContainer"
                                android:fontFamily="@font/cairo_regular" />

                            <TextView
                                android:id="@+id/tv_shift_status_badge"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/shift_status_open"
                                android:textSize="@dimen/text_xl"
                                android:textStyle="bold"
                                android:fontFamily="@font/cairo_bold"
                                android:layout_marginTop="@dimen/spacing_xxs" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- ──────────────────────────────────── -->
                    <!-- Open Shift Details (visible when open) -->
                    <!-- ──────────────────────────────────── -->
                    <LinearLayout
                        android:id="@+id/layout_shift_open"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="@dimen/spacing_base"
                        android:visibility="gone">

                        <!-- Divider -->
                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="?attr/colorOutlineVariant"
                            android:layout_marginBottom="@dimen/spacing_base" />

                        <!-- Stats Grid (2 columns) -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <!-- Opening Cash -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/bg_stat_box"
                                android:padding="@dimen/spacing_md"
                                android:layout_marginEnd="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/shift_opening_cash_title"
                                    android:textSize="@dimen/text_xs"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:fontFamily="@font/cairo_regular" />

                                <TextView
                                    android:id="@+id/tv_opening_cash"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:textSize="@dimen/text_base"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurface"
                                    android:fontFamily="@font/cairo_bold"
                                    android:layout_marginTop="@dimen/spacing_xs" />
                            </LinearLayout>

                            <!-- Opened At -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/bg_stat_box"
                                android:padding="@dimen/spacing_md"
                                android:layout_marginStart="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/shift_opened_at_title"
                                    android:textSize="@dimen/text_xs"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:fontFamily="@font/cairo_regular" />

                                <TextView
                                    android:id="@+id/tv_opened_at"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="--:--"
                                    android:textSize="@dimen/text_md"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurface"
                                    android:fontFamily="@font/cairo_bold"
                                    android:layout_marginTop="@dimen/spacing_xs" />
                            </LinearLayout>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:weightSum="2"
                            android:layout_marginTop="@dimen/spacing_md">

                            <!-- Current Sales -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/bg_stat_box"
                                android:padding="@dimen/spacing_md"
                                android:layout_marginEnd="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/shift_current_sales_title"
                                    android:textSize="@dimen/text_xs"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:fontFamily="@font/cairo_regular" />

                                <TextView
                                    android:id="@+id/tv_current_sales"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0.00"
                                    android:textSize="@dimen/text_base"
                                    android:textStyle="bold"
                                    android:textColor="@color/color_success"
                                    android:fontFamily="@font/cairo_bold"
                                    android:layout_marginTop="@dimen/spacing_xs" />
                            </LinearLayout>

                            <!-- Invoice Count -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:background="@drawable/bg_stat_box"
                                android:padding="@dimen/spacing_md"
                                android:layout_marginStart="6dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/shift_invoice_count_title"
                                    android:textSize="@dimen/text_xs"
                                    android:textColor="?attr/colorOnSurfaceVariant"
                                    android:fontFamily="@font/cairo_regular" />

                                <TextView
                                    android:id="@+id/tv_invoice_count"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="@dimen/text_base"
                                    android:textStyle="bold"
                                    android:textColor="?attr/colorOnSurface"
                                    android:fontFamily="@font/cairo_bold"
                                    android:layout_marginTop="@dimen/spacing_xs" />
                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ──────────────────────────────────── -->
                    <!-- No Shift Placeholder                 -->
                    <!-- ──────────────────────────────────── -->
                    <LinearLayout
                        android:id="@+id/layout_no_shift"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:visibility="visible">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shift_no_open_desc"
                            android:textSize="@dimen/text_sm"
                            android:textColor="?attr/colorOnSurfaceVariant"
                            android:gravity="center"
                            android:fontFamily="@font/cairo_regular" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════ -->
            <!-- Open Shift Section (no shift active)    -->
            <!-- ════════════════════════════════════════ -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="@dimen/spacing_sm"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_lg">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/shift_enter_opening_cash"
                        android:textSize="@dimen/text_md"
                        android:textColor="?attr/colorOnSurface"
                        android:fontFamily="@font/cairo_semibold"
                        android:layout_marginBottom="@dimen/spacing_md" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/shift_opening_cash_hint"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:startIconDrawable="@drawable/ic_attach_money"
                        app:startIconTint="?attr/colorPrimary"
                        android:layout_marginBottom="@dimen/spacing_base">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/et_opening_cash"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:imeOptions="actionDone" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_open_shift"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/shift_open_btn"
                        android:textSize="@dimen/text_base"
                        android:fontFamily="@font/cairo_semibold"
                        style="@style/Widget.Material3.Button"
                        app:icon="@drawable/ic_add"
                        app:iconGravity="textStart"
                        app:cornerRadius="24dp"
                        android:visibility="visible" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_close_shift"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="@string/shift_close_btn"
                        android:textSize="@dimen/text_base"
                        android:fontFamily="@font/cairo_semibold"
                        style="@style/Widget.Material3.Button.TonalButton"
                        app:icon="@drawable/ic_check"
                        app:iconGravity="textStart"
                        app:cornerRadius="24dp"
                        app:backgroundTint="?attr/colorErrorContainer"
                        android:textColor="?attr/colorOnErrorContainer"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ════════════════════════════════════════ -->
            <!-- Shift History Section Header            -->
            <!-- ════════════════════════════════════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingTop="@dimen/spacing_sm"
                android:paddingBottom="@dimen/spacing_sm">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_calendar"
                    android:tint="?attr/colorPrimary"
                    android:contentDescription="@string/shift_history_title" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/shift_history_title"
                    android:textSize="@dimen/text_base"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"
                    android:fontFamily="@font/cairo_bold"
                    android:layout_marginStart="@dimen/spacing_sm" />

            </LinearLayout>

            <!-- Empty state for history -->
            <TextView
                android:id="@+id/tv_no_shifts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/shift_no_history"
                android:textSize="@dimen/text_md"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:gravity="center"
                android:fontFamily="@font/cairo_regular"
                android:paddingVertical="@dimen/spacing_xxl"
                android:visibility="gone" />

            <!-- ════════════════════════════════════════ -->
            <!-- Shift History RecyclerView              -->
            <!-- ════════════════════════════════════════ -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_shifts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false"
                android:paddingBottom="@dimen/spacing_sm" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
