<?xml version="1.0" encoding="utf-8"?>
<!-- ملف drawable/scanner_frame.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    
    <!-- الخلفية الشفافة -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="0dp"
                android:color="#00000000" />
        </shape>
    </item>
    
    <!-- الإطار الخارجي -->
    <item>
        <shape android:shape="rectangle">
            <stroke
                android:width="3dp"
                android:color="#FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>
    
    <!-- الزوايا -->
    <item
        android:top="0dp"
        android:left="0dp"
        android:right="260dp"
        android:bottom="260dp">
        <shape android:shape="rectangle">
            <solid android:color="#6750A4" />
            <size
                android:width="20dp"
                android:height="20dp" />
        </shape>
    </item>
    
    <item
        android:top="0dp"
        android:right="0dp"
        android:left="260dp"
        android:bottom="260dp">
        <shape android:shape="rectangle">
            <solid android:color="#6750A4" />
            <size
                android:width="20dp"
                android:height="20dp" />
        </shape>
    </item>
    
    <item
        android:bottom="0dp"
        android:left="0dp"
        android:right="260dp"
        android:top="260dp">
        <shape android:shape="rectangle">
            <solid android:color="#6750A4" />
            <size
                android:width="20dp"
                android:height="20dp" />
        </shape>
    </item>
    
    <item
        android:bottom="0dp"
        android:right="0dp"
        android:left="260dp"
        android:top="260dp">
        <shape android:shape="rectangle">
            <solid android:color="#6750A4" />
            <size
                android:width="20dp"
                android:height="20dp" />
        </shape>
    </item>
    
</layer-list>