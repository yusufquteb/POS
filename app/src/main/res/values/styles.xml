<?xml version='1.0' encoding='utf-8'?>
<!--
    styles.xml - نظام الثيمات الكامل
    ══════════════════════════════════════════════════════════════
    المبدأ الموحَّد:
    ─────────────────
    • كل ثيم يُعيِّن ?attr/colorPrimary عبر Material3
    • الملفات القديمة تستخدم @color/primary = @color/colorPrimary
      وكلاهما يشيران لنفس اللون المُعيَّن في الثيم الافتراضي
    • عند تغيير الثيم يُعيد التطبيق onCreate() فيُطبَّق التغيير

    الثيمات المتاحة (يُطبِّقها ThemeManager):
    ─────────────────
    Light:  AppTheme_Blue | AppTheme_Purple | AppTheme_Green | AppTheme_Orange | AppTheme_Teal
    Dark:   AppTheme_Blue_Dark | AppTheme_Purple_Dark | AppTheme_Green_Dark | ...
    ══════════════════════════════════════════════════════════════
-->
<resources>

    <!-- ╔══════════════════════════════════════════════════════╗ -->
    <!-- ║         BASE LIGHT THEME (أزرق افتراضي)            ║ -->
    <!-- ╚══════════════════════════════════════════════════════╝ -->
    <style name="AppTheme" parent="Theme.Material3.Light.NoActionBar">
        <!-- Material3 Color System -->
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryDark">@color/blue_primary_variant</item>
        <item name="colorPrimaryVariant">@color/blue_primary_variant</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/blue_secondary</item>
        <item name="colorSecondaryVariant">@color/blue_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="colorAccent">@color/blue_secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/white</item>
        <!-- Status / Nav bars -->
        <item name="android:statusBarColor">@color/blue_primary</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">true</item>
        <!-- Typography -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:fontFamily">@font/cairo</item>
        <item name="fontFamily">@font/cairo</item>
    </style>

    <!-- ╔══════════════════════════════════════════════════════╗ -->
    <!-- ║         BASE DARK THEME (داكن افتراضي)             ║ -->
    <!-- ╚══════════════════════════════════════════════════════╝ -->
    <style name="AppTheme_Dark" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/blue_dark_primary</item>
        <item name="colorPrimaryDark">@color/blue_dark_primary_container</item>
        <item name="colorPrimaryVariant">@color/blue_dark_primary_container</item>
        <item name="colorOnPrimary">@color/dark_on_primary</item>
        <item name="colorSecondary">@color/blue_dark_secondary</item>
        <item name="colorSecondaryVariant">@color/blue_dark_secondary</item>
        <item name="colorOnSecondary">@color/dark_on_primary</item>
        <item name="colorAccent">@color/blue_dark_secondary</item>
        <item name="android:colorBackground">@color/dark_background</item>
        <item name="colorSurface">@color/dark_surface</item>
        <item name="colorOnSurface">@color/dark_text_primary</item>
        <item name="colorOnBackground">@color/dark_text_primary</item>
        <item name="colorError">@color/dark_error</item>
        <item name="colorOnError">@color/dark_on_primary</item>
        <item name="android:statusBarColor">@color/blue_dark_primary</item>
        <item name="android:navigationBarColor">@color/dark_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:textColorPrimary">@color/dark_text_primary</item>
        <item name="android:textColorSecondary">@color/dark_text_secondary</item>
        <item name="android:textColorHint">@color/dark_text_hint</item>
        <item name="android:windowBackground">@color/dark_background</item>
        <item name="android:fontFamily">@font/cairo</item>
        <item name="fontFamily">@font/cairo</item>
    </style>

    <!-- ╔══════════════════════════════════════════════════════╗ -->
    <!-- ║   LIGHT COLOR VARIANTS (ثيمات فاتحة ملوّنة)        ║ -->
    <!-- ╚══════════════════════════════════════════════════════╝ -->
    <style name="AppTheme_Blue"   parent="AppTheme">
        <item name="colorPrimary">@color/blue_primary</item>
        <item name="colorPrimaryDark">@color/blue_primary_variant</item>
        <item name="colorPrimaryVariant">@color/blue_primary_variant</item>
        <item name="colorSecondary">@color/blue_secondary</item>
        <item name="colorAccent">@color/blue_secondary</item>
        <item name="android:statusBarColor">@color/blue_primary</item>
    </style>

    <style name="AppTheme_Purple" parent="AppTheme">
        <item name="colorPrimary">@color/purple_primary</item>
        <item name="colorPrimaryDark">@color/purple_primary_variant</item>
        <item name="colorPrimaryVariant">@color/purple_primary_variant</item>
        <item name="colorSecondary">@color/purple_secondary</item>
        <item name="colorAccent">@color/purple_secondary</item>
        <item name="android:statusBarColor">@color/purple_primary</item>
    </style>

    <style name="AppTheme_Green" parent="AppTheme">
        <item name="colorPrimary">@color/green_primary</item>
        <item name="colorPrimaryDark">@color/green_primary_variant</item>
        <item name="colorPrimaryVariant">@color/green_primary_variant</item>
        <item name="colorSecondary">@color/green_secondary</item>
        <item name="colorAccent">@color/green_secondary</item>
        <item name="android:statusBarColor">@color/green_primary</item>
    </style>

    <style name="AppTheme_Orange" parent="AppTheme">
        <item name="colorPrimary">@color/orange_primary</item>
        <item name="colorPrimaryDark">@color/orange_primary_variant</item>
        <item name="colorPrimaryVariant">@color/orange_primary_variant</item>
        <item name="colorSecondary">@color/orange_secondary</item>
        <item name="colorAccent">@color/orange_secondary</item>
        <item name="android:statusBarColor">@color/orange_primary</item>
    </style>

    <style name="AppTheme_Teal" parent="AppTheme">
        <item name="colorPrimary">@color/teal_primary</item>
        <item name="colorPrimaryDark">@color/teal_primary_variant</item>
        <item name="colorPrimaryVariant">@color/teal_primary_variant</item>
        <item name="colorSecondary">@color/teal_secondary</item>
        <item name="colorAccent">@color/teal_secondary</item>
        <item name="android:statusBarColor">@color/teal_primary</item>
    </style>

    <!-- ╔══════════════════════════════════════════════════════╗ -->
    <!-- ║   DARK COLOR VARIANTS (ثيمات داكنة ملوّنة)         ║ -->
    <!-- ╚══════════════════════════════════════════════════════╝ -->
    <style name="AppTheme_Blue_Dark"   parent="AppTheme_Dark">
        <item name="colorPrimary">@color/blue_dark_primary</item>
        <item name="colorPrimaryDark">@color/blue_dark_primary_container</item>
        <item name="colorPrimaryVariant">@color/blue_dark_primary_container</item>
        <item name="colorSecondary">@color/blue_dark_secondary</item>
        <item name="colorAccent">@color/blue_dark_secondary</item>
        <item name="android:statusBarColor">@color/blue_dark_primary</item>
    </style>

    <style name="AppTheme_Purple_Dark" parent="AppTheme_Dark">
        <item name="colorPrimary">@color/purple_dark_primary</item>
        <item name="colorPrimaryDark">@color/purple_dark_primary_container</item>
        <item name="colorPrimaryVariant">@color/purple_dark_primary_container</item>
        <item name="colorSecondary">@color/purple_dark_secondary</item>
        <item name="colorAccent">@color/purple_dark_secondary</item>
        <item name="android:statusBarColor">@color/purple_dark_primary</item>
    </style>

    <style name="AppTheme_Green_Dark" parent="AppTheme_Dark">
        <item name="colorPrimary">@color/green_dark_primary</item>
        <item name="colorPrimaryDark">@color/green_dark_primary_container</item>
        <item name="colorPrimaryVariant">@color/green_dark_primary_container</item>
        <item name="colorSecondary">@color/green_dark_secondary</item>
        <item name="colorAccent">@color/green_dark_secondary</item>
        <item name="android:statusBarColor">@color/green_dark_primary</item>
    </style>

    <style name="AppTheme_Orange_Dark" parent="AppTheme_Dark">
        <item name="colorPrimary">@color/orange_dark_primary</item>
        <item name="colorPrimaryDark">@color/orange_dark_primary_container</item>
        <item name="colorPrimaryVariant">@color/orange_dark_primary_container</item>
        <item name="colorSecondary">@color/orange_dark_secondary</item>
        <item name="colorAccent">@color/orange_dark_secondary</item>
        <item name="android:statusBarColor">@color/orange_dark_primary</item>
    </style>

    <style name="AppTheme_Teal_Dark" parent="AppTheme_Dark">
        <item name="colorPrimary">@color/teal_dark_primary</item>
        <item name="colorPrimaryDark">@color/teal_dark_primary_container</item>
        <item name="colorPrimaryVariant">@color/teal_dark_primary_container</item>
        <item name="colorSecondary">@color/teal_dark_secondary</item>
        <item name="colorAccent">@color/teal_dark_secondary</item>
        <item name="android:statusBarColor">@color/teal_dark_primary</item>
    </style>

    <!-- ╔══════════════════════════════════════════════════════╗ -->
    <!-- ║   SPECIAL THEMES                                    ║ -->
    <!-- ╚══════════════════════════════════════════════════════╝ -->
    <style name="Theme.App.Starting" parent="Theme.Material3.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="AppTheme.Splash" parent="Theme.App.Starting"/>

    <style name="AppTheme.Auth" parent="AppTheme">
        <item name="android:windowBackground">@color/background</item>
    </style>

    <style name="AppTheme.Transparent" parent="AppTheme">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsTranslucent">true</item>
    </style>

    <!-- ╔══════════════════════════════════════════════════════╗ -->
    <!-- ║   WIDGET STYLES (مشتركة بين الثيمات)               ║ -->
    <!-- ╚══════════════════════════════════════════════════════╝ -->
    <style name="ToolbarTheme" parent="ThemeOverlay.Material3.Dark.ActionBar">
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/white</item>
        <item name="colorControlNormal">@color/white</item>
    </style>

    <style name="CardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <style name="CardStyle_Outlined" parent="Widget.Material3.CardView.Outlined">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">?attr/colorOutline</item>
    </style>

    <style name="Widget.MyFirstWords.CardView" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">6dp</item>
    </style>

    <style name="ButtonStyle" parent="Widget.Material3.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ButtonStyle_Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="ButtonStyle_Text" parent="Widget.Material3.Button.TextButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ButtonStyle_Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:minHeight">56dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextInputStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">?attr/colorPrimary</item>
    </style>

    <style name="TextInputStyle_Dense" parent="Widget.Material3.TextInputLayout.OutlinedBox.Dense">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <style name="TextAppearance.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.Body" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">16sp</item>
    </style>

    <style name="TextAppearance.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
    </style>

    <style name="DialogStyle" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="cornerRadius">20dp</item>
        <item name="android:backgroundDimAmount">0.6</item>
    </style>

    <style name="BottomSheetStyle" parent="Widget.Material3.BottomSheet">
        <item name="shapeAppearanceOverlay">@style/BottomSheetShapeAppearance</item>
    </style>

    <style name="BottomSheetShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">20dp</item>
        <item name="cornerSizeTopRight">20dp</item>
    </style>

    <style name="SwitchStyle" parent="Widget.Material3.CompoundButton.MaterialSwitch">
        <item name="thumbTint">?attr/colorPrimary</item>
        <item name="trackTint">?attr/colorPrimaryContainer</item>
    </style>

    <style name="DividerStyle" parent="Widget.Material3.MaterialDivider">
        <item name="dividerColor">@color/divider</item>
        <item name="dividerThickness">1dp</item>
    </style>

    <style name="ChipStyle" parent="Widget.Material3.Chip.Assist">
        <item name="chipCornerRadius">16dp</item>
        <item name="chipMinHeight">32dp</item>
    </style>

    <style name="FABStyle" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="shapeAppearanceOverlay">@style/FABShapeAppearance</item>
    </style>

    <style name="FABShapeAppearance" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ListItemStyle">
        <item name="android:minHeight">64dp</item>
        <item name="android:paddingStart">16dp</item>
        <item name="android:paddingEnd">16dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
    </style>

</resources>
