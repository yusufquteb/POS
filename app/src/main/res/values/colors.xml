<?xml version="1.0" encoding="utf-8"?>
<!--
╔══════════════════════════════════════════════════════════════════╗
║                    colors.xml - نظام الألوان الموحَّد           ║
╠══════════════════════════════════════════════════════════════════╣
║  المبدأ:                                                        ║
║  ─────────────────────────────────────────────────────          ║
║  1. كل ثيم (Blue, Purple, Green, Orange, Teal) له:             ║
║     • نسخة فاتحة: xxx_primary / xxx_secondary                  ║
║     • نسخة داكنة: xxx_dark_primary / xxx_dark_secondary        ║
║                                                                  ║
║  2. الألوان المشتركة (shared) لا تتغير بين الثيمات:            ║
║     • white, background, surface, text_primary...               ║
║                                                                  ║
║  3. الأسماء القديمة (primary, colorPrimary) تساوي الافتراضي    ║
║     وتُستخدَم في الملفات القديمة فقط.                          ║
║                                                                  ║
║  4. الـ UI الجديد يستخدم ?attr/colorPrimary دائماً             ║
║     لضمان التغيير الديناميكي مع الثيم.                         ║
╚══════════════════════════════════════════════════════════════════╝
-->
<resources>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  SHARED NEUTRAL COLORS (مشتركة - لا تتغير بالثيم)    -->
    <!-- ══════════════════════════════════════════════════════ -->

    <!-- أبيض وأسود -->
    <color name="white">#FFFFFF</color>
    <color name="black">#000000</color>

    <!-- خلفيات وأسطح (فاتح) -->
    <color name="background">#FAFAFA</color>
    <color name="surface">#FFFFFF</color>
    <color name="surface_variant">#F5F5F5</color>
    <color name="divider">#E0E0E0</color>

    <!-- خلفيات وأسطح (داكن) -->
    <color name="dark_background">#121212</color>
    <color name="dark_surface">#1E1E1E</color>
    <color name="dark_surface_variant">#2C2C2C</color>
    <color name="dark_divider">#3A3A3A</color>
    <color name="dark_on_primary">#FFFFFF</color>

    <!-- نصوص فاتح -->
    <color name="text_primary">#212121</color>
    <color name="text_secondary">#757575</color>
    <color name="text_hint">#BDBDBD</color>

    <!-- نصوص داكن -->
    <color name="dark_text_primary">#EEEEEE</color>
    <color name="dark_text_secondary">#BDBDBD</color>
    <color name="dark_text_hint">#757575</color>

    <!-- أخطاء -->
    <color name="error">#B00020</color>
    <color name="error_container">#FFEBEE</color>
    <color name="dark_error">#CF6679</color>

    <!-- رمادي (Material palette) -->
    <color name="gray_100">#F5F5F5</color>
    <color name="gray_200">#EEEEEE</color>
    <color name="gray_300">#E0E0E0</color>
    <color name="gray_400">#BDBDBD</color>
    <color name="gray_500">#9E9E9E</color>
    <color name="gray_600">#757575</color>
    <color name="gray_700">#616161</color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  BLUE THEME — الأزرق (الافتراضي)                     -->
    <!-- ══════════════════════════════════════════════════════ -->
    <color name="blue_primary">#1565C0</color>
    <color name="blue_primary_variant">#0D47A1</color>
    <color name="blue_primary_container">#BBDEFB</color>
    <color name="blue_secondary">#29B6F6</color>
    <color name="blue_secondary_variant">#0277BD</color>
    <!-- داكن -->
    <color name="blue_dark_primary">#90CAF9</color>
    <color name="blue_dark_primary_container">#1E3A5F</color>
    <color name="blue_dark_secondary">#4FC3F7</color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  PURPLE THEME — البنفسجي                             -->
    <!-- ══════════════════════════════════════════════════════ -->
    <color name="purple_primary">#6A1B9A</color>
    <color name="purple_primary_variant">#4A148C</color>
    <color name="purple_primary_container">#E1BEE7</color>
    <color name="purple_secondary">#AB47BC</color>
    <color name="purple_secondary_variant">#7B1FA2</color>
    <!-- داكن -->
    <color name="purple_dark_primary">#CE93D8</color>
    <color name="purple_dark_primary_container">#3D1256</color>
    <color name="purple_dark_secondary">#BA68C8</color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  GREEN THEME — الأخضر                                -->
    <!-- ══════════════════════════════════════════════════════ -->
    <color name="green_primary">#2E7D32</color>
    <color name="green_primary_variant">#1B5E20</color>
    <color name="green_primary_container">#C8E6C9</color>
    <color name="green_secondary">#66BB6A</color>
    <color name="green_secondary_variant">#388E3C</color>
    <!-- داكن -->
    <color name="green_dark_primary">#A5D6A7</color>
    <color name="green_dark_primary_container">#1B3A1E</color>
    <color name="green_dark_secondary">#81C784</color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  ORANGE THEME — البرتقالي                            -->
    <!-- ══════════════════════════════════════════════════════ -->
    <color name="orange_primary">#E65100</color>
    <color name="orange_primary_variant">#BF360C</color>
    <color name="orange_primary_container">#FFE0B2</color>
    <color name="orange_secondary">#FFA726</color>
    <color name="orange_secondary_variant">#F57C00</color>
    <!-- داكن -->
    <color name="orange_dark_primary">#FFCC80</color>
    <color name="orange_dark_primary_container">#5C2400</color>
    <color name="orange_dark_secondary">#FFB74D</color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  TEAL THEME — الفيروزي                               -->
    <!-- ══════════════════════════════════════════════════════ -->
    <color name="teal_primary">#00695C</color>
    <color name="teal_primary_variant">#004D40</color>
    <color name="teal_primary_container">#B2DFDB</color>
    <color name="teal_secondary">#26A69A</color>
    <color name="teal_secondary_variant">#00796B</color>
    <!-- داكن -->
    <color name="teal_dark_primary">#80CBC4</color>
    <color name="teal_dark_primary_container">#003D35</color>
    <color name="teal_dark_secondary">#4DB6AC</color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  LEGACY ALIASES — أسماء قديمة تشير للأزرق الافتراضي  -->
    <!--  (تُستخدَم في ملفات Sketchware القديمة فقط)           -->
    <!--  لا تغيّرها — الـ UI الجديد يستخدم ?attr/colorPrimary -->
    <!-- ══════════════════════════════════════════════════════ -->
    <color name="primary">@color/blue_primary</color>
    <color name="primary_dark">@color/blue_primary_variant</color>
    <color name="primary_variant">@color/blue_primary_variant</color>
    <color name="secondary">@color/blue_secondary</color>
    <color name="secondary_variant">@color/blue_secondary_variant</color>
    <color name="accent">@color/blue_secondary</color>
    <color name="colorPrimary">@color/blue_primary</color>
    <color name="colorPrimaryDark">@color/blue_primary_variant</color>
    <color name="colorAccent">@color/blue_secondary</color>
    <color name="dark_primary">@color/blue_dark_primary</color>
    <color name="dark_primary_variant">@color/blue_dark_primary_container</color>

    <!-- Legacy md_theme names → new names -->
    <color name="md_theme_blue_dark_primary">@color/blue_dark_primary</color>
    <color name="md_theme_blue_dark_primaryContainer">@color/blue_dark_primary_container</color>
    <color name="md_theme_purple_dark_primary">@color/purple_dark_primary</color>
    <color name="md_theme_purple_dark_primaryContainer">@color/purple_dark_primary_container</color>
    <color name="md_theme_green_dark_primary">@color/green_dark_primary</color>
    <color name="md_theme_green_dark_primaryContainer">@color/green_dark_primary_container</color>
    <color name="md_theme_orange_dark_primary">@color/orange_dark_primary</color>
    <color name="md_theme_orange_dark_primaryContainer">@color/orange_dark_primary_container</color>
    <color name="md_theme_teal_dark_primary">@color/teal_dark_primary</color>
    <color name="md_theme_teal_dark_primaryContainer">@color/teal_dark_primary_container</color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  SEMANTIC COLORS — دلالية (لا تتغير بالثيم)          -->
    <!-- ══════════════════════════════════════════════════════ -->
    <color name="color_success">#2E7D32</color>
    <color name="color_error">#B00020</color>
    <color name="color_error_light">#FFEBEE</color>
    <color name="color_warning">#FF8F00</color>
    <color name="color_info">#1565C0</color>
    <color name="low_stock_color">#FF6F00</color>
    <color name="out_of_stock_color">#C62828</color>
    <color name="color_success_light">#E8F5E9</color>
    <color name="color_warning_light">#FFF8E1</color>

    <!-- ══════════════════════════════════════════════════════ -->
    <!--  SPECIAL COLORS — ألوان خاصة                        -->
    <!-- ══════════════════════════════════════════════════════ -->
    <!-- Premium / Gold -->
    <color name="gold">#F9A825</color>
    <color name="gold_dark">#F57F17</color>
    <color name="gold_light">#FFF8E1</color>

    <!-- Purple standalone (للعناصر البنفسجية في أي ثيم) -->
    <color name="purple_500">#9C27B0</color>

    <!-- Launcher -->
    <color name="ic_launcher_background">#1565C0</color>
    <color name="ic_launcher_foreground">#FFFFFF</color>

</resources>
